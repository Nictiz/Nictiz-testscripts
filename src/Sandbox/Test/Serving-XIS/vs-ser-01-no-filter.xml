<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="http://hl7.org/fhir/STU3/testscript.sch" type="application/xml" schematypens="http://purl.oclc.org/dsdl/schematron"?>
<TestScript xmlns="http://hl7.org/fhir" xmlns:nts="http://nictiz.nl/xsl/testscript"
    nts:scenario="server">
    <id value="vs-ser-01-no-filter"/>
    <version value="stu3-2.0"/>
    <title value="Scenario 01 - Serve vital signs resources"/>
    <description value="Serve all vital signs resources of patient XXX_Bourgonjee basic requests"/>
    <nts:authToken patientResourceId="selfmeasurement-patient-kwalificatie1" id="XXX_Bourgonjee"/>
    <nts:includeDateT value="yes"/>

    <test id="test-01-serve-patient-resource">
        <name value="Test 01 Patient Resource"/>
        <description value="Serve patient resource"/>
        <nts:include value="medmij/test.xis.search" scope="common"
            resource="Patient"
            params="?_include=Patient:general-practitioner"/>
        <nts:include value="assert.response.numResources" scope="common"
            resource="Patient" count="1"/>
        <nts:include value="assert.response.numResources" scope="common"
            resource="Practitioner" count="1"/>        
    </test>

    <test id="test-02-serve-respiration-resource">
        <name value="Test 02 Respiration Resource"/>
        <description value="Serve respiration resource"/>
        <nts:include value="medmij/test.xis.search" scope="common"
            resource="Observation"
            params="?code=http://snomed.info/sct|422834003"/>
        <nts:include value="canary-assert.response.successfulSearch" scope="common"/>
        <nts:include value="assert.response.numResources" scope="common"
            resource="Observation" count="0"/>
    </test>

    <test id="test-03-serve-bloodpressure-resource">
