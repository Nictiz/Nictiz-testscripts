<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="http://hl7.org/fhir/STU3/testscript.sch" type="application/xml" schematypens="http://purl.oclc.org/dsdl/schematron"?>
<TestScript xmlns="http://hl7.org/fhir" xmlns:nts="http://nictiz.nl/xsl/testscript"
    nts:scenario="client">
    <id value="vs-send-01-minimal-1-zib"/>
    <version value="stu3-2.0"/>
    <title value="Scenario 1"/>
    <description value="Send vital signs per minimal filled HCIM"/>
    <nts:authToken patientResourceId="selfmeasurements-Patient-XXX-Herder"/>
    <nts:fixture id="scenario-1-1-bundle-fixture"
        href="bundles/send/selfmeasurements-send-scenario-1-1-respiration-bundle.xml"/>
    <nts:fixture id="scenario-2-1-bundle-fixture"
        href="bundles/send/selfmeasurements-send-scenario-2-1-bodyheight-bundle.xml"/>
    <nts:fixture id="scenario-3-1-bundle-fixture"
        href="bundles/send/selfmeasurements-send-scenario-3-1-bodytemp-bundle.xml"/>
    <nts:fixture id="scenario-4-1-bundle-fixture"
        href="bundles/send/selfmeasurements-send-scenario-4-1-saturation-bundle.xml"/>
    <nts:fixture id="scenario-5-1-bundle-fixture"
        href="bundles/send/selfmeasurements-send-scenario-5-1-pulserate-bundle.xml"/>
    <nts:fixture id="scenario-6-1-bundle-fixture"
        href="bundles/send/selfmeasurements-send-scenario-6-1-bloodpressure-bundle.xml"/>
    <nts:fixture id="scenario-7-1-bundle-fixture"
        href="bundles/send/selfmeasurements-send-scenario-7-1-bodyweight-bundle.xml"/>
    <nts:fixture id="scenario-8-1-bundle-fixture"
        href="bundles/send/selfmeasurements-send-scenario-8-1-bloodglucose-bundle.xml"/>
    <nts:fixture id="scenario-9-1-bundle-fixture"
        href="bundles/send/selfmeasurements-send-scenario-9-1-heartrate-bundle.xml"/>
        
    <nts:includeDateT value="yes"/>

    <test id="send-01-01-send-one-minimal-respiration">
        <name value="Scenario 1.1"/>
        <description value="Send one minimal respiration Observation resource"/>
        <nts:include value="medmij/test.phr.successfulBatch" scope="common"
            sourceId="scenario-1-1-bundle-fixture"/>
        <nts:include value="assert.request.numResources" scope="common"
            resource="Observation" count="1"/>
        <action>
            <assert>
                <description value="Confirm that the observation resource has the correct respiration value"/>
                <direction value="request"/>
                <expression value="Bundle.entry.resource.ofType(Observation).component.where(code.coding.code='9279-1' and code.coding.system='http://loinc.org').value.ofType(Quantity).where(value=16 and code.matches('^\\{.+\\}/min$')).exists()"/>
            </assert>
        </action>
    </test>
    <test id="send-01-02-send-one-minimal-bodyheight">
        <name value="Scenario 1.2"/>
        <description value="Send one minimal body height Observation resource"/>
        <nts:include value="medmij/test.phr.successfulBatch" scope="common"
            sourceId="scenario-2-1-bundle-fixture"/>
        <nts:include value="assert.request.numResources" scope="common"
            resource="Observation" count="1"/>
        <action>
            <assert>
                <description value="Confirm that the latest observation resource has the correct bodyheight value"/>
                <direction value="request"/>
                <expression value="Bundle.entry.resource.ofType(Observation).where(code.coding.where(code='8302-2' and system='http://loinc.org')).value.ofType(Quantity).where(value=192 and code='cm').exists()"/>
            </assert>
        </action>
    </test>
    <test id="send-01-03-send-one-minimal-bodytemp">
        <name value="Scenario 1.3"/>
        <description value="Send one minimal body temperature Observation resource"/>
        <nts:include value="medmij/test.phr.successfulBatch" scope="common"
            sourceId="scenario-3-1-bundle-fixture"/>
        <nts:include value="assert.request.numResources" scope="common"
            resource="Observation" count="1"/>
        <action>
            <assert>
                <description value="Confirm that the latest observation resource has the correct bodyTemperature value"/>
                <direction value="request"/>
                <expression value="Bundle.entry.resource.ofType(Observation).where(code.coding.code='8310-5' and code.coding.system='http://loinc.org').value.ofType(Quantity).where(value=37.2 and code='Cel').exists()"/>
            </assert>
        </action>
    </test>
    <test id="send-01-04-send-one-minimal-saturation">
        <name value="Scenario 1.4"/>
        <description value="Send one minimal saturation Observation resource"/>
        <nts:include value="medmij/test.phr.successfulBatch" scope="common"
            sourceId="scenario-4-1-bundle-fixture"/>
        <nts:include value="assert.request.numResources" scope="common"
            resource="Observation" count="1"/>
        <action>
            <assert>
                <description value="Confirm that the latest observation resource has the correct saturation value"/>
                <direction value="request"/>
                <expression value="Bundle.entry.resource.ofType(Observation).where(code.coding.code='59408-5' and code.coding.system='http://loinc.org').value.ofType(Quantity).where(value=94 and code='%').exists()"/>
            </assert>
        </action>
    </test>
    <test id="send-01-05-send-one-minimal-pulserate">
        <name value="Scenario 1.5"/>
        <description value="Send one minimal pulse rate Observation resource"/>
        <nts:include value="medmij/test.phr.successfulBatch" scope="common"
            sourceId="scenario-5-1-bundle-fixture"/>
        <nts:include value="assert.request.numResources" scope="common"
            resource="Observation" count="1"/>
        <action>
            <assert>
                <description value="Confirm that the latest observation resource has the correct PulseRate value"/>
                <direction value="request"/>
                <expression value="Bundle.entry.resource.ofType(Observation).where(code.coding.code='8893-0' and code.coding.system='http://loinc.org').value.ofType(Quantity).where(value=64 and code='/min').exists()"/>
            </assert>
        </action>
    </test>
    <test id="send-01-06-send-one-minimal-bloodpressure">
        <name value="Scenario 1.6"/>
        <description value="Send one minimal blood pressure Observation resource"/>
        <nts:include value="medmij/test.phr.successfulBatch" scope="common"
            sourceId="scenario-6-1-bundle-fixture"/>
        <nts:include value="assert.request.numResources" scope="common"
            resource="Observation" count="1"/>
        <action>
            <assert>
                <description value="Confirm that the latest observation resource has the correct bloodpressure value"/>
                <direction value="request"/>
                <expression value="Bundle.entry.resource.ofType(Observation).component.where(code.coding.code='8480-6').value.where(value=121 and code='mm[Hg]').exists()"/>
            </assert>
        </action>
    </test>
    <test id="send-01-08-send-one-minimal-bloodglucose">
        <name value="Scenario 1.8"/>
        <description value="Send one minimal blood glucose Observation resource"/>
        <nts:include value="medmij/test.phr.successfulBatch" scope="common"
            sourceId="scenario-8-1-bundle-fixture"/>
        <nts:include value="assert.request.numResources" scope="common"
            resource="Observation" count="1"/>
        <action>
            <assert>
                <description value="Confirm that the latest observation resource has the correct bloodglucose value"/>
                <direction value="request"/>
                <expression value="Bundle.entry.resource.ofType(Observation).value.where(value=5.4 and code='mmol/L').exists()"/>
            </assert>
        </action>
    </test>
    <test id="send-01-09-send-one-minimal-heartrate">
        <name value="Scenario 1.9"/>
        <description value="Send one minimal heart rate Observation resource"/>
        <nts:include value="medmij/test.phr.successfulBatch" scope="common"
            sourceId="scenario-9-1-bundle-fixture"/>
        <nts:include value="assert.request.numResources" scope="common"
            resource="Observation" count="1"/>
        <action>
            <assert>
                <description value="Confirm that the latest observation resource has the correct heartrate value"/>
                <direction value="request"/>
                <expression value="Bundle.entry.resource.ofType(Observation).where(code.coding.code='8867-4' and code.coding.system='http://loinc.org').value.ofType(Quantity).where(value=62 and code='/min').exists()"/>
            </assert>
        </action>
    </test>
</TestScript>
