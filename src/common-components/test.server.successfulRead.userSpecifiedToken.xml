<?xml version="1.0" encoding="UTF-8"?>
<!--
    XIS test to successfully read a specific resource, to be added to `TestScript.test`.
    It is expected that a token is imported using nts:authToken.
    @param resource - The resource type to read.
    @param params - The parameters to add to the request URL (usually the id of the resource to read).
    @param useToken - If set, the authorization header is included with the value of the token that is imported using nts:authToken. The content of this variable doesn't matter.
    @param allowCodeWithoutSystem - If set, the resource is allowed to have a .code without a .system. The content of this variable doesn't actually matter.
-->
<nts:component xmlns="http://hl7.org/fhir" xmlns:nts="http://nictiz.nl/xsl/testscript">
    <variable>
        <name value="auth-token"/>
        <description value="Enter the OAuth Token of your system or test patient"/>
    </variable>

    <nts:include value="test.server.read" scope="common"/>
    <action>
        <operation>
            <type>
                <system value="http://hl7.org/fhir/restful-interaction"/>
                <code value="read"/>
            </type>
            <resource value="{$resource}"/>
            <description nts:ifnotset="description" value="Test Server to serve {$resource} resources."/>
            <description nts:ifset="description" value="{$description}"/>
            <destination value="1"/>
            <origin value="1"/>
            <params nts:ifset="params" value="{$params}"/>
            <requestHeader>
                <field value="Authorization"/>
                <value value="${auth-token}"/>
            </requestHeader>
            <responseId nts:ifset="responseId" value="{$responseId}"/>
        </operation>
    </action>

    <nts:include value="assert.response.success" scope="common"/>
    <nts:include value="_assert.general.resourceContent" scope="common" direction="response" resourceBase="{$resource}"/>
</nts:component>
