<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="../../../lib/Nictiz-tooling-testscripts/1.5.0/schematron/NictizTestScript.sch" type="application/xml" schematypens="http://purl.oclc.org/dsdl/schematron"?>
<!--
    Server test to read a specific resource, to be added to `TestScript.test`. It is expected that a token is imported using nts:authToken.
    @param resource - The resource to read.
    @param params - The parameters to add to the request URL (usually the id of the resource to read).
    @param [useToken] - Optional, if set, the authorization header is included with the value of the token that is imported using nts:authToken. The content of this variable doesn't matter.
    @param [responseId] - An optional id to cache the response from the server to. 
-->
<nts:component xmlns="http://hl7.org/fhir" xmlns:nts="http://nictiz.nl/xsl/testscript">
    <variable nts:ifset="useOwnToken">
        <name value="auth-token"/>
        <description value="Enter the OAuth Token of your system or test patient"/>
    </variable>

    <action>
        <operation>
            <type>
                <system value="http://hl7.org/fhir/restful-interaction"/>
                <code value="read"/>
            </type>
            <resource value="{$resource}"/>
            <description value="Test server to serve {$resource} resource."/>
            <destination value="1"/>
            <origin value="1"/>
            <params value="{$params}"/>
            <requestHeader nts:ifset="useOwnToken">
                <field value="Authorization"/>
                <value value="${auth-token}"/>
            </requestHeader>
            <nts:include nts:ifset="useToken" value="header.request.PatientToken" scope="common"/>
            <responseId nts:ifset="responseId" value="{$responseId}"/>
        </operation>
    </action>
</nts:component>
