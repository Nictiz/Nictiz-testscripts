<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="http://hl7.org/fhir/STU3/testscript.sch" type="application/xml" schematypens="http://purl.oclc.org/dsdl/schematron"?>
<TestScript xmlns="http://hl7.org/fhir" xmlns:nts="http://nictiz.nl/xsl/testscript" 
    nts:scenario="client">
    <id value="elz-retrieve-treatmentDirective-test-1-Minimaal"/>
    <version value="R4"/>
    <name value="TreatmentDirective - Client - Test 1 Minimaal - Retrieve Consent resources of Patient XXX_vanHenegouwen"/>
    <title value="TreatmentDirective - Retrieve Consent resources of Patient XXX_vanHenegouwen"/>
    <description value="MinimaalBericht - Retrieve Consent resources of Patient XXX_vanHenegouwen"/>
    <nts:authToken patientResourceId="patient-XXX-vanHenegouwen"/>
    
    <test>
        <name value="Scenario 1.1 - Retrieve Consent resources"/>
        <description value="Query Consent resource"/>
        <nts:include value="test.client.search" scope="common"
                     resource="Consent"
                     params="?scope=http://terminology.hl7.org/CodeSystem/consentscope|treatment&amp;patient.identifier=http://fhir.nl/fhir/NamingSystem/bsn|555555112&amp;status=active"
                     useToken="true"/>
        <nts:include value="canary-assert.response.successfulSearch" scope="common"/>
        <nts:include value="assert.response.numResources" scope="common" resource="Consent" count="1"/>
    </test>
</TestScript>