<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="http://hl7.org/fhir/STU3/testscript.sch" type="application/xml" schematypens="http://purl.oclc.org/dsdl/schematron"?>
<TestScript xmlns="http://hl7.org/fhir" xmlns:nts="http://nictiz.nl/xsl/testscript" 
    nts:scenario="client">
    <id value="elz-retrieve-treatmentDirective-test-2-Maximaal"/>
    <version value="R4"/>
    <name value="TreatmentDirective - Client - Test 2 Maximaal - Retrieve Consent resources of Patient XXX_vanAnkeren"/>
    <title value="TreatmentDirective - Retrieve Consent resources of Patient XXX_vanAnkeren"/>
    <description value="MaximaalBericht - Retrieve Consent resources of Patient XXX_vanAnkeren"/>
    <nts:authToken patientResourceId="patient-van--XXX-vanAnkeren-de-Jong"/>
    
    <test>
        <name value="Scenario 1.1 - Retrieve Consent resources"/>
        <description value="Query Consent resource"/>
        <nts:include value="test.client.search" scope="common"
                     resource="Consent"
                     params="?scope=http://terminology.hl7.org/CodeSystem/consentscope|treatment&amp;patient.identifier=http://fhir.nl/fhir/NamingSystem/bsn|999999023&amp;status=active"
                     useToken="true"/>
        <nts:include value="canary-assert.response.successfulSearch" scope="common"/>
        <nts:include value="assert.response.numResources" scope="common" resource="Consent" count="6"/>
    </test>
    <test>
        <name value="Scenario 1.2 - Retrieve Consent resources and include relatedperson/actor and patient"/>
        <description value="Query Consent resource"/>
        <nts:include value="test.client.search" scope="common"
                     resource="Consent"
                     params="?scope=http://terminology.hl7.org/CodeSystem/consentscope|treatment&amp;patient.identifier=http://fhir.nl/fhir/NamingSystem/bsn|999999023&amp;status=active&amp;_include=Consent:actor&amp;_include=Consent:patient"
                     useToken="true"/>
        <nts:include value="canary-assert.response.successfulSearch" scope="common"/>
        <nts:include value="assert.response.numResources" scope="common" resource="Consent" count="6"/>
        <nts:include value="assert.response.numResources" scope="common" resource="RelatedPerson" count="2"/>
        <nts:include value="assert.response.numResources" scope="common" resource="Patient" count="1"/>
    </test>
</TestScript>