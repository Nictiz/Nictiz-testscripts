<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="http://hl7.org/fhir/STU3/testscript.sch" type="application/xml" schematypens="http://purl.oclc.org/dsdl/schematron"?>
<TestScript xmlns="http://hl7.org/fhir" xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="server">
    <id value="elz-serving-xis-scenario-2-Maximaal"/>
    <version value="R4"/>
    <name value="ELZ - Serving XIS - Scenario 2 Maximaal - Serving Consent resources of patient XXX_vanAnkeren"/>
    <description value="Scenario 1 - Serving Consent resources of patient XXX_vanAnkeren"/>
    <nts:authToken patientResourceId="patient-van--XXX-vanAnkeren-de-Jong"/>
    
    <test id="serve-Consent-Resources-Maximaal">
        <name value="Serving Consent resources of patient XXX_vanAnkeren"/>
        <description
            value="Serve Consent resources of patient XXX_vanAnkeren"/>
        <nts:include value="test.server.successfulRead" scope="common"
                     resource="Consent"
                     params="?scope=http://terminology.hl7.org/CodeSystem/consentscope|treatment&amp;patient.identifier=http://fhir.nl/fhir/NamingSystem/bsn|999999023&amp;status=active&amp;_include=Consent:actor&amp;_include=Consent:patient"
                     useToken="true"/>
        <nts:include value="assert.response.numResources" scope="common"
                     resource="Patient" count="1" nts:in-targets="#default"/>
        <nts:include value="assert.response.numResources" scope="common"
                     resource="PractitionerRole" count="1" nts:in-targets="#default"/>
        <nts:include value="assert.response.numResources" scope="common"
                     resource="Consent" count="6" nts:in-targets="#default"/>
        
        <nts:contentAsserts href="resources\Patient-patient-van--XXX-vanAnkeren-de-Jong.xml.xml"
                            nts:in-targets="CheckContent"/>
        <nts:contentAsserts href="resources\PractitionerRole-pracrole-000001111.xml"
                            nts:in-targets="CheckContent"/>
        
        <nts:contentAsserts href="resources\Consent-td-2020-06-07-32485007.xml"
                            description="contains provision.code.coding.code = '32485007'" 
                            discriminator="provision.where(code.where(coding.where(code = '32485007')))" 
                            nts:in-targets="CheckContent"/>
        <nts:contentAsserts href="resources\Consent-td-2020-06-07-305351004.xml"
                            description="contains provision.code.coding.code = '305351004'" 
                            discriminator="provision.where(code.where(coding.where(code = '305351004')))" 
                            nts:in-targets="CheckContent"/>
        <nts:contentAsserts href="resources\Consent-td-2022-05-04-89666000.xml"
                            description="contains provision.code.coding.code = '89666000'" 
                            discriminator="provision.where(code.where(coding.where(code = '89666000')))" 
                            nts:in-targets="CheckContent"/>
        <nts:contentAsserts href="resources\Consent-td-2024-11-12-40617009.xml"
                            description="contains provision.code.coding.code = '40617009'" 
                            discriminator="provision.where(code.where(coding.where(code = '40617009')))" 
                            nts:in-targets="CheckContent"/>
        <nts:contentAsserts href="resources\Consent-td-2025-04-02-116762002.xml"
                            description="contains provision.code.coding.code = '116762002'" 
                            discriminator="provision.where(code.where(coding.where(code = '116762002')))" 
                            nts:in-targets="CheckContent"/>
        <nts:contentAsserts href="resources\Consent-td-2025-04-02-OTH.xml"
                            description="contains provision.code.coding.code = 'OTH'" 
                            discriminator="provision.where(code.where(coding.where(code = 'OTH')))" 
                            nts:in-targets="CheckContent"/>
        
    </test>
    
</TestScript>
