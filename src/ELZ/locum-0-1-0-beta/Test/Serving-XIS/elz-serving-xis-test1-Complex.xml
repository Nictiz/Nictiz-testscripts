<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="http://hl7.org/fhir/STU3/testscript.sch" type="application/xml" schematypens="http://purl.oclc.org/dsdl/schematron"?>
<TestScript xmlns="http://hl7.org/fhir" xmlns:nts="http://nictiz.nl/xsl/testscript"
    nts:scenario="server">
    <id value="elz-serving-xis-scenario-1-complex"/>
    <version value="R4"/>
    <name value="ELZ - Serving XIS - Scenario 1 Complex - Serving Consent resources of patient XXX_Mutter"/>
    <description value="Scenario 1 - Serving Consent resources of patient XXX_Mutter"/>
    <nts:authToken patientResourceId="patient-XXX-Mutter"/>

    <test id="serve-Consent-Resources-Complex">
        <name value="Serving Consent resources of patient XXX_Mutter"/>
        <description
            value="Serve Consent resources of patient XXX_Mutter"/>
        <nts:include value="test.server.successfulRead" scope="common"
            resource="Consent"
            params="?scope=http://terminology.hl7.org/CodeSystem/consentscope|treatment&amp;patient.identifier=http://fhir.nl/fhir/NamingSystem/bsn|999911673&amp;status=active&amp;_include=Consent:actor&amp;_include=Consent:patient"
            useToken="true"/>
        <nts:include value="assert.response.numResources" scope="common"
                     resource="Patient" count="1" nts:in-targets="#default"/>
        <nts:include value="assert.response.numResources" scope="common"
                     resource="PractitionerRole" count="1" nts:in-targets="#default"/>
        <nts:include value="assert.response.numResources" scope="common"
                     resource="Consent" count="6" nts:in-targets="#default"/>
        
        <nts:contentAsserts href="resources/Patient-patient-XXX-Mutter.xml"
                            nts:in-targets="CheckContent"/>
        <nts:contentAsserts href="resources/PractitionerRole-pracrole-UZI-7.xml"
                            nts:in-targets="CheckContent"/>
        
        <nts:contentAsserts href="resources/Consent-td-2020-05-06-116762002.xml"
                            description="contains provision.code.coding.code = '116762002'" 
                            discriminator="provision.where(code.where(coding.where(code = '116762002')))" 
                            nts:in-targets="CheckContent"/>
        <nts:contentAsserts href="resources/Consent-td-2024-12-01-32485007.xml"
                            description="contains provision.code.coding.code = '32485007'" 
                            discriminator="provision.where(code.where(coding.where(code = '32485007')))" 
                            nts:in-targets="CheckContent"/>
        <nts:contentAsserts href="resources/Consent-td-2024-12-01-40617009.xml"
                            description="contains provision.code.coding.code = '40617009'" 
                            discriminator="provision.where(code.where(coding.where(code = '40617009')))" 
                            nts:in-targets="CheckContent"/>
        <nts:contentAsserts href="resources/Consent-td-2024-12-01-89666000.xml"
                            description="contains provision.code.coding.code = '89666000'" 
                            discriminator="provision.where(code.where(coding.where(code = '89666000')))" 
                            nts:in-targets="CheckContent"/>
        <nts:contentAsserts href="resources/Consent-td-2024-12-01-305351004.xml"
                            description="contains provision.code.coding.code = '305351004'" 
                            discriminator="provision.where(code.where(coding.where(code = '305351004')))" 
                            nts:in-targets="CheckContent"/>
        <nts:contentAsserts href="resources/Consent-td-2024-12-01-OTH.xml"
                            description="contains provision.code.coding.code = 'OTH'" 
                            discriminator="provision.where(code.where(coding.where(code = 'OTH')))" 
                            nts:in-targets="CheckContent"/>
        
    </test>

</TestScript>
