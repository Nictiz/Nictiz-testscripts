<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="http://hl7.org/fhir/STU3/testscript.sch" type="application/xml" schematypens="http://purl.oclc.org/dsdl/schematron"?>
<TestScript xmlns="http://hl7.org/fhir" xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="server">
    <id value="elz-serving-xis-scenario-3-Minimaal"/>
    <version value="R4"/>
    <name value="ELZ - Serving XIS - Scenario 3 Minimaal - Serving Consent resources of patient XXX_vanHenegouwen"/>
    <description value="Scenario 3 - Serving Consent resources of patient XXX_vanHenegouwen"/>
    <nts:authToken patientResourceId="patient-XXX-vanHenegouwen"/>
    
    <test id="serve-Consent-Resources-Minimaal">
        <name value="Serving Consent resources of patient XXX_vanHenegouwen"/>
        <description
            value="Serve Consent resources of patient XXX_vanHenegouwen"/>
        <nts:include value="test.server.successfulSearch" scope="common"
                     resource="Consent"
                     params="?scope=http://terminology.hl7.org/CodeSystem/consentscope|treatment&amp;patient.identifier=http://fhir.nl/fhir/NamingSystem/bsn|555555112&amp;status=active&amp;_include=Consent:actor&amp;_include=Consent:patient"
                     useToken="true"/>
        <nts:include value="assert.response.numResources" scope="common"
                     resource="Patient" count="1" nts:in-targets="#default"/>
        <nts:include value="assert.response.numResources" scope="common"
                     resource="PractitionerRole" count="1" nts:in-targets="#default"/>
        <nts:include value="assert.response.numResources" scope="common"
                     resource="Consent" count="1" nts:in-targets="#default"/>
        
        <nts:contentAsserts href="resources/Patient-patient-XXX-vanHenegouwen.xml"
                            nts:in-targets="CheckContent"/>
        <nts:contentAsserts href="resources/PractitionerRole-pracrole-UZI1.xml"
                            nts:in-targets="CheckContent"/>
        
        <nts:contentAsserts href="resources/Consent-td-2025-08-09-40617009.xml"
                            description="contains provision.code.coding.code = '40617009'" 
                            discriminator="provision.where(code.where(coding.where(code = '40617009')))" 
                            nts:in-targets="CheckContent"/>
        
    </test>
    
</TestScript>
