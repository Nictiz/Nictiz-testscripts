<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="http://hl7.org/fhir/STU3/testscript.sch" type="application/xml" schematypens="http://purl.oclc.org/dsdl/schematron"?>
<TestScript xmlns="http://hl7.org/fhir" xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="server">
    <id value="elz-serving-xis-scenario-4-ZonderBA"/>
    <version value="R4"/>
    <name value="ELZ - Serving XIS - Scenario 4 ZonderBA - Serving Consent resources of patient XXX_Weele"/>
    <description value="Scenario 4 - Serving Consent resources of patient XXX_Weele"/>
    <nts:authToken patientResourceId="patient-XXX-Weele"/>
    
    <test id="serve-Consent-Resources-ZonderBehandelAanwijzing">
        <name value="Serving Consent resources of patient XXX_Weele"/>
        <description
            value="Serve Consent resources of patient XXX_Weele"/>
        <nts:include value="test.server.successfulSearch" scope="common"
                     resource="Consent"
                     params="?scope=http://terminology.hl7.org/CodeSystem/consentscope|treatment&amp;patient.identifier=http://fhir.nl/fhir/NamingSystem/bsn|999910255&amp;status=active&amp;_include=Consent:actor&amp;_include=Consent:patient"
                     useToken="true"/>
        <nts:include value="assert.response.numResources" scope="common"
                     resource="Patient" count="1" nts:in-targets="#default"/>
        <nts:include value="assert.response.numResources" scope="common"
                     resource="PractitionerRole" count="1" nts:in-targets="#default"/>
        <nts:include value="assert.response.numResources" scope="common"
                     resource="Consent" count="0" nts:in-targets="#default"/>
        
    </test>
    
</TestScript>
