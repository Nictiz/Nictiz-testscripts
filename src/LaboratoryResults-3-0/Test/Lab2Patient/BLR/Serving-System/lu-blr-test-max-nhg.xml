<TestScript nts:scenario="server"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            xmlns="http://hl7.org/fhir">
   <id value="lu-blr-max-nhg"/>
   <version value="r4-lab-3.0.0-beta.4"/>
   <name value="LaboratoryResults - Server - Scenario 1.4 - Serve DiagnosticReport"/>
   <title value="LaboratoryResults - Server - Scenario 1.4 - Serve DiagnosticReport"/>
   <description value="Scenario 1.4 - Serve DiagnosticReport for P. XXX_Doppen"/>
   <nts:authToken patientResourceId="nl-core-Patient-lab-E-XXX-Doppen"/>
   <test id="scenario1-4-serve-diagnosticreport">
      <name value="Scenario 1.4"/>
      <description value="Serve DiagnosticReport for P. XXX_Doppen"/>
      <nts:include value="medmij/test.xis.search"
                   scope="common">
         <nts:with-parameter name="description"
                             value="Test XIS to serve DiagnosticReport resource"/>
         <nts:with-parameter name="resource"
                             value="DiagnosticReport"/>
         <nts:with-parameter name="params"
                             value="?category=http://terminology.hl7.org/CodeSystem/observation-category|laboratory&amp;code=https://referentiemodel.nhg.org/tabellen/nhg-tabel-45-diagnostische-bepalingen|3272&amp;_include=DiagnosticReport:result&amp;_include=DiagnosticReport:performer&amp;_include=DiagnosticReport:subject"/>
      </nts:include>
      <nts:include value="assert.response.successfulSearch"
                   scope="common"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="Observation"
                   count="1"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="Patient"
                   count="1"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="Organization"
                   count="2"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="Practitioner"
                   count="1"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="PractitionerRole"
                   count="1"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="Specimen"
                   count="1"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="ServiceRequest"
                   count="1"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="DiagnosticReport"
                   count="1"/>
   </test>
</TestScript>