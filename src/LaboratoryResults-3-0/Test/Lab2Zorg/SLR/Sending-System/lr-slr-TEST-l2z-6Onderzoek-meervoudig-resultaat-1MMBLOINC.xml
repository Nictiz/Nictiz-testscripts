<TestScript nts:scenario="client"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            xmlns="http://hl7.org/fhir">
   <id value="lr-slr-l2z-6Onderzoek-meervoudig-resultaat-1MMBLOINC"/>
   <version value="r4-lab-3.0.0-beta.4"/>
   <name value="LaboratoryResults - Client - Scenario 6.1 - Send Observation"/>
   <title value="LaboratoryResults - Client - Scenario 6.1 - Send Observation"/>
   <description value="Scenario 6.1 - Send Observation for P. Erelies"/>
   <nts:authToken patientResourceId="nl-core-Patient-lab-E-Erelies"/>
   <nts:fixture id="lr-slr-TEST-l2z-6Onderzoek-meervoudig-resultaat-1MMBLOINC"
                href="resources-to-sendreceive/lr-slr-TEST-l2z-6Onderzoek-meervoudig-resultaat-1MMBLOINC.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes"
                     nts:in-targets="Nictiz-intern"/>
   <test id="scenario6-1-send-observation">
      <name value="Scenario 6.1"/>
      <description value="Send Observation for P. Erelies"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response-fixture"/>
            <sourceId value="lr-slr-TEST-l2z-6Onderzoek-meervoudig-resultaat-1MMBLOINC"
                      nts:in-targets="Nictiz-intern"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction"
                   scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Observation"
                   count="3"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Specimen"
                   count="1"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Organization"
                   count="1"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Patient"
                   count="1"/>
      <action>
         <assert>
            <description value="Confirm that the Observation resource has a LOINC code for Herpes-simplexvirus 1 &amp; 2 DNA panel d.m.v. moleculaire techniek (PCR) in the code element"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Observation).code.coding.where(code = '87431-3').exists()"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the Observation resource has a LOINC code for Herpes-simplexvirus 1 DNA [aanwezigheid] d.m.v. moleculaire techniek (PCR) in the code element"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Observation).code.coding.where(code = '16130-7').exists()"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the Observation resource has a LOINC code for Herpes-simplexvirus 2 DNA [aanwezigheid] d.m.v. moleculaire techniek (PCR) in the code element"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Observation).code.coding.where(code = '16131-5').exists()"/>
         </assert>
      </action>
   </test>
</TestScript>