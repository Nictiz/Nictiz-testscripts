<TestScript nts:scenario="server"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            xmlns="http://hl7.org/fhir">
   <id value="lr-slr-l2z-3Gecorrigeerd-bericht-2BMMBNHGCorrectie"/>
   <version value="r4-lab-3.0.0-beta.4"/>
   <name value="LaboratoryResults - Server - Scenario 3.2 - Receive Observation"/>
   <title value="LaboratoryResults - Server - Scenario 3.2 - Receive Observation"/>
   <description value="Scenario 3.2 - Receive Observation for P. Erelies"/>
   <nts:authToken patientResourceId="nl-core-Patient-lab-E-Erelies"/>
   <nts:fixture id="lr-slr-TEST-l2z-3Gecorrigeerd-bericht-2BMMBNHGCorrectie"
                href="resources-to-sendreceive/lr-slr-TEST-l2z-3Gecorrigeerd-bericht-2BMMBNHGCorrectie.{$_FORMAT}"/>
   <nts:includeDateT value="yes"/>
   <test id="scenario3-2-receive-observation">
      <name value="Scenario 3.2"/>
      <description value="Receive Observation for P. Erelies"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test server to handle a Bundle of type transaction."/>
            <contentType value="{$_FORMAT}"/>
            <destination value="1"/>
            <origin value="1"/>
            <requestHeader>
               <field value="Prefer"/>
               <value value="return=representation"/>
            </requestHeader>
            <sourceId value="lr-slr-TEST-l2z-3Gecorrigeerd-bericht-2BMMBNHGCorrectie"/>
         </operation>
      </action>
      <nts:include value="assert.response.success"
                   scope="common"/>
      <nts:include value="assert.response.bundleContent"
                   scope="common"
                   bundleType="transaction-response"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Observation"
                   count="1"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Specimen"
                   count="1"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Organization"
                   count="1"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Patient"
                   count="1"/>
      <action>
         <assert>
            <description value="Confirm that the Observation resource has a NHG code for SARS-CoV-2 RNA (COVID-19) keel (PCR) kz in the code element"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Observation).code.coding.where(code = '4029').exists()"/>
         </assert>
      </action>
      <teardown nts:in-targets="Nictiz-intern">
         <action>
            <operation>
               <type>
                  <system value="http://hl7.org/fhir/restful-interaction"/>
                  <code value="delete"/>
               </type>
               <code value="om de aangemaakte resources te verwijderen"/>
            </operation>
         </action>
      </teardown>
   </test>
</TestScript>