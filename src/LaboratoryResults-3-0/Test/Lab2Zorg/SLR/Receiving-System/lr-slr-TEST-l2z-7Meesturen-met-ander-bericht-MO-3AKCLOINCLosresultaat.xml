<TestScript nts:scenario="server"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            xmlns="http://hl7.org/fhir">
   <id value="lr-slr-l2z-7Meesturen-MO-3AKCLOINCLosresultaat"/>
   <version value="r4-lab-3.0.0-beta.4"/>
   <name value="LaboratoryResults - Server - Scenario 7.3 - Receive Observation"/>
   <title value="LaboratoryResults - Server - Scenario 7.3 - Receive Observation"/>
   <description value="Scenario 7.3 - Receive Observation for P. XXX_Doppen"/>
   <nts:authToken patientResourceId="nl-core-Patient-lab-E-XXX-Doppen"/>
   <nts:fixture id="r-TEST-l2z-7Meesturen-met-ander-bericht-MO-3AKCLOINCLosresultaat"
                href="resources-to-sendreceive/lr-slr-TEST-l2z-7Meesturen-met-ander-bericht-MO-3AKCLOINCLosresultaat.{$_FORMAT}"/>
   <nts:includeDateT value="yes"/>
   <test id="scenario7-3-receive-observation">
      <name value="Scenario 7.3"/>
      <description value="Receive Observation for P. XXX_Doppen"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test server to handle a Bundle of type transaction."/>
            <contentType value="{$_FORMAT}"/>
            <destination value="1"/>
            <origin value="1"/>
            <requestHeader>
               <field value="Prefer"/>
               <value value="return=representation"/>
            </requestHeader>
            <sourceId value="r-TEST-l2z-7Meesturen-met-ander-bericht-MO-3AKCLOINCLosresultaat"/>
         </operation>
      </action>
      <nts:include value="assert.response.success"
                   scope="common"/>
      <nts:include value="assert.response.bundleContent"
                   scope="common"
                   bundleType="transaction-response"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Observation"
                   count="2"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Organization"
                   count="1"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Patient"
                   count="1"/>
      <action>
         <assert>
            <description value="Confirm that the Observation resource has a LOINC code for Glomerulaire filtratiesnelheid/1,73 m2.voorspeld [filtratiesnelheid/oppervlakte] in serum of plasma of bloed d.m.v. formule gebaseerd op creatinine (CKD-EPI 2021) in the code element"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Observation).code.coding.where(code = '98979-8').exists()"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the Observation resource has a LOINC code for Creatinine [mol/volume] in urine in the code element"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Observation).code.coding.where(code = '45066-8').exists()"/>
         </assert>
      </action>
      <teardown nts:in-targets="Nictiz-intern">
         <action>
            <operation>
               <type>
                  <system value="http://hl7.org/fhir/restful-interaction"/>
                  <code value="delete"/>
               </type>
               <code value="om de aangemaakte resources te verwijderen"/>
            </operation>
         </action>
      </teardown>
   </test>
</TestScript>