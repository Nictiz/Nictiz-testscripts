<TestScript nts:scenario="client"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            xmlns="http://hl7.org/fhir">
   <id value="lr-loa-l2z-1Maximaal-bericht-aanvraag-3KCLOINC"/>
   <version value="r4-lab-3.0.0-beta.4"/>
   <name value="LaboratoryResults - Client - Scenario 1.3 - Send DiagnosticReport"/>
   <title value="LaboratoryResults - Client - Scenario 1.3 - Send DiagnosticReport"/>
   <description value="Scenario 1.3 - Send DiagnosticReport for P. XXX_Doppen"/>
   <nts:authToken patientResourceId="nl-core-Patient-lab-E-XXX-Doppen"/>
   <nts:fixture id="lr-loa-KWAL-l2z-1Maximaal-bericht-aanvraag-3KCLOINC"
                href="resources-to-sendreceive-on-request/lr-loa-KWAL-l2z-1Maximaal-bericht-aanvraag-3KCLOINC.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes"
                     nts:in-targets="Nictiz-intern"/>
   <test id="scenario1-3-send-diagnosticreport">
      <name value="Scenario 1.3"/>
      <description value="Send DiagnosticReport for P. XXX_Doppen"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response-fixture"/>
            <sourceId value="lr-loa-KWAL-l2z-1Maximaal-bericht-aanvraag-3KCLOINC"
                      nts:in-targets="Nictiz-intern"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction"
                   scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Observation"
                   count="1"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="DiagnosticReport"
                   count="1"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="ServiceRequest"
                   count="1"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="PractitionerRole"
                   count="1"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Practitioner"
                   count="1"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Specimen"
                   count="1"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Organization"
                   count="1"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Patient"
                   count="1"/>
      <action>
         <assert>
            <description value="Confirm that the Observation resource has a LOINC code for Glucose [mol/volume] in capillair bloed in the code element"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Observation).code.coding.where(code = '51596-5').exists()"/>
         </assert>
      </action>
   </test>
</TestScript>