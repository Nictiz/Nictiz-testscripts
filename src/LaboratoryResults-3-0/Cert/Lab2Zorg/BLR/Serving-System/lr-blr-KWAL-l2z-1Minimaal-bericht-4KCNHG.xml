<TestScript nts:scenario="server"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            xmlns="http://hl7.org/fhir">
   <id value="lr-blr-l2z-1Minimaal-bericht-4KCNHG"/>
   <version value="r4-lab-3.0.0-beta.4"/>
   <name value="LaboratoryResults - Server - Scenario 1.4 - Serve Observation"/>
   <title value="LaboratoryResults - Server - Scenario 1.4 - Serve Observation"/>
   <description value="Scenario 1.4 - Serve Observation for P. XXX_Doppen"/>
   <nts:authToken patientResourceId="nl-core-Patient-lab-E-XXX-Doppen"/>
   <test id="scenario1-4-serve-observation">
      <name value="Scenario 1.4"/>
      <description value="Serve Observation for P. XXX_Doppen"/>
      <nts:include value="test.server.search"
                   scope="common">
         <nts:with-parameter name="description"
                             value="Test server to serve Observation resource"/>
         <nts:with-parameter name="resource"
                             value="Observation"/>
         <nts:with-parameter name="params"
                             value="?patient.identifier=http://fhir.nl/fhir/NamingSystem/bsn|999900511&amp;category=http://terminology.hl7.org/CodeSystem/observation-category|laboratory&amp;code=https://referentiemodel.nhg.org/tabellen/nhg-tabel-45-diagnostische-bepalingen|111&amp;_include=Observation:specimen&amp;_include=Observation:performer&amp;_include=Observation:subject"/>
      </nts:include>
      <nts:include value="assert.response.successfulSearch"
                   scope="common"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="Observation"
                   count="1"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="Patient"
                   count="1"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="Organization"
                   count="1"/>
   </test>
</TestScript>