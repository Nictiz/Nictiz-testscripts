<TestScript nts:scenario="client"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            xmlns="http://hl7.org/fhir">
   <id value="lu-blr-AB-loinc"/>
   <version value="r4-lab-3.0.0-beta.4"/>
   <name value="LaboratoryResults - Client - Scenario 3.3 - Retrieve DiagnosticReport"/>
   <title value="LaboratoryResults - Client - Scenario 3.3 - Retrieve DiagnosticReport"/>
   <description value="Scenario 3.3 - Retrieve DiagnosticReport for P. XXX_Doppen"/>
   <nts:authToken patientResourceId="nl-core-Patient-lab-E-XXX-Doppen"/>
   <test id="scenario3-3-retrieve-diagnosticreport">
      <name value="Scenario 3.3"/>
      <description value="Retrieve DiagnosticReport for P. XXX_Doppen"/>
      <nts:include value="medmij/test.phr.search"
                   scope="common">
         <nts:with-parameter name="description"
                             value="Test PHR to retrieve DiagnosticReport resource"/>
         <nts:with-parameter name="resource"
                             value="DiagnosticReport"/>
         <nts:with-parameter name="params"
                             value="?result.category=http://terminology.hl7.org/CodeSystem/observation-category|laboratory&amp;result.code=http://loinc.org|46418-0,3016-3,50384-7,50384-7,50384-7&amp;_include=DiagnosticReport:result&amp;_include=DiagnosticReport:performer&amp;_include=DiagnosticReport:subject"/>
      </nts:include>
      <nts:include value="canary-assert.response.successfulSearch"
                   scope="common"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="Observation"
                   count="5"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="Patient"
                   count="1"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="Organization"
                   count="2"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="Specimen"
                   count="5"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="Practitioner"
                   count="1"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="PractitionerRole"
                   count="1"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="ServiceRequest"
                   count="1"/>
      <nts:include value="assert.response.numResources"
                   scope="common"
                   resource="DiagnosticReport"
                   count="1"/>
   </test>
</TestScript>