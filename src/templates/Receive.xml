<?xml version="1.0" encoding="UTF-8"?>
<!--
    NTS template for a FHIR TestScript for a receiving system.

    Usage:
    - Copy this file to an NTS input folder, for example:
      src/<InformationStandard>/<Test|Cert>/Receiving-System/<testscript-id>.xml
    - Make sure the same folder contains a src-properties.json with role.name
      for the receiving system.
    - Add the Bundle fixture under the configured reference folder, usually:
      src/<InformationStandard>/<Test|Cert>/_reference/bundles/receive/
    - Replace all TODO values before running the NTS build.

    The NTS build generates a regular FHIR TestScript resource from this source
    in the output folder configured in build.properties.
-->
<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="server">
    <id value="TODO-receive-testscript-id"/> <!-- Best practice = same as filename. Regex: [A-Za-z0-9\-\.]{1,64} -->
    <version value="TODO-version"/>
    <title value="TODO - Receive TODO-resource for TODO-patient"/> <!-- A short, descriptive, user-friendly title for the test script. -->
    <description value="TestScript for a receiving system that receives TODO-resource(s) from the test system."/> <!-- Write a clear description from a consumer's perspective. You can add URLs. -->

    <!--
        Only needed when the receive action must be performed with a patient token.
        patientResourceId must exist in Configuration/QualificationTokens.json.
    -->
    <nts:authToken patientResourceId="TODO-patient-resource-id" id="TODO-visible-patient-identifier"/>

    <!--
        The href is relative to the _reference folder. Use {$_FORMAT} when both XML and JSON
        fixture variants are generated and the TestScript should follow the current output format.
    -->
    <nts:fixture id="TODO-receive-bundle-fixture"
                 href="bundles/receive/TODO-receive-bundle.{$_FORMAT}"/>

    <!-- Set to yes when the TestScript needs a Date T variable. -->
    <nts:includeDateT value="no"/>

    <test id="01-receive-TODO-bundle">
        <name value="01 - Receive TODO Bundle"/>
        <description value="Receive a Bundle with TODO-resource(s) from the test system."/>

        <nts:include value="test.server.transaction"
                     scope="common"
                     sourceId="TODO-receive-bundle-fixture"
                     useToken="true"/>
        <nts:include value="assert.response.success" scope="common"/>
        <nts:include value="assert.response.bundleContent"
                     scope="common"
                     bundleType="transaction-response"/>

        <nts:include value="assert.response.numResources"
                     scope="common"
                     resource="TODOResourceType"
                     count="TODO-expected-count"/>
    </test>
</TestScript>
