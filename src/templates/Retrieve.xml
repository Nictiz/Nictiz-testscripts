<?xml version="1.0" encoding="UTF-8"?>
<!--
    NTS template for a FHIR TestScript for a retrieving system.

    Usage:
    - Copy this file to an NTS input folder, for example:
      src/<InformationStandard>/<Test|Cert>/Retrieving-System/<testscript-id>.xml
    - Make sure the same folder contains a src-properties.json with role.name
      for the retrieving system.
    - Replace all TODO values before running the NTS build.

    The NTS build generates a regular FHIR TestScript resource from this source
    in the output folder configured in build.properties.
-->
<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
    <id value="TODO-retrieve-testscript-id"/> <!--Best practice = same as filename	Regex: [A-Za-z0-9\-\.]{1,64} -->
    <version value="TODO-version"/>
    <title value="TODO - retrieve of TODO-resource for TODO-patient"/> <!-- A short, descriptive, user-friendly title for the test script. -->
    <description value="TestScript for a retrieving system that retrieves TODO-resource(s) from the test server."/> <!-- Write a clear description from a consumers perspective. You can add urls-->

    <!--
        Only needed when the retrieve action must be performed with a patient token.
        patientResourceId must exist in Configuration/QualificationTokens.json.
    -->
    <nts:authToken patientResourceId="TODO-patient-resource-id" id="TODO-visible-patient-identifier"/>

    <!-- Set to yes when the TestScript needs a Date T variable. -->
    <nts:includeDateT value="no"/>

    <test id="01-search-TODO-resource">
        <name value="01 - Search TODO-resource"/>
        <description value="Retrieve TODO-resource(s) for the test patient with a FHIR search."/>

        <nts:include value="test.client.search"
                     scope="common"
                     resource="TODOResourceType"
                     params="?patient.identifier=TODO-system|TODO-value"
                     useToken="true"
                     responseId="search-TODO-resource-response">
            <nts:with-parameter name="description"
                                value="Test client to retrieve TODOResourceType resource(s) for the test patient."/>
        </nts:include>

        <nts:include value="canary-assert.response.successfulSearch" scope="common"/>
        <nts:include value="assert.response.numResources"
                     scope="common"
                     resource="TODOResourceType"
                     count="TODO-expected-count"/>
    </test>

    <test id="02-read-TODO-resource">
        <name value="02 - Read TODO-resource"/>
        <description value="Retrieve a specific TODO-resource that is offered by the test server."/>

        <nts:include value="test.client.successfulRead"
                     scope="common"
                     resource="TODOResourceType"
                     params="/TODO-resource-id"/>
    </test>
</TestScript>
