<?xml version="1.0" encoding="UTF-8"?>
<!--
    NTS template for a FHIR TestScript for a serving system.

    Usage:
    - Copy this file to an NTS input folder, for example:
      src/<InformationStandard>/<Test|Cert>/Serving-System/<testscript-id>.xml
    - Make sure the same folder contains a src-properties.json with role.name
      for the serving system.
    - Replace all TODO values before running the NTS build.

    The NTS build generates a regular FHIR TestScript resource from this source
    in the output folder configured in build.properties.
-->
<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="server">
    <id value="TODO-serve-testscript-id"/> <!-- Best practice = same as filename. Regex: [A-Za-z0-9\-\.]{1,64} -->
    <version value="TODO-version"/>
    <title value="TODO - Serve TODO-resource for TODO-patient"/> <!-- A short, descriptive, user-friendly title for the test script. -->
    <description value="TestScript for a serving system that serves TODO-resource(s) to a retrieving system."/> <!-- Write a clear description from a consumer's perspective. You can add URLs. -->

    <!--
        Only needed when the serve action must be performed with a patient token.
        patientResourceId must exist in Configuration/QualificationTokens.json.
    -->
    <nts:authToken patientResourceId="TODO-patient-resource-id" id="TODO-visible-patient-identifier"/>

    <!-- Set to yes when the TestScript needs a Date T variable. -->
    <nts:includeDateT value="no"/>

    <test id="01-serve-TODO-resource-search">
        <name value="01 - Serve TODO-resource search"/>
        <description value="Make TODO-resource(s) available for a FHIR search from the test system."/>

        <nts:include value="test.server.successfulSearch"
                     scope="common"
                     resource="TODOResourceType"
                     params="?patient.identifier=TODO-system|TODO-value"
                     useToken="true"
                     responseId="serve-TODO-resource-search-response">
            <nts:with-parameter name="description"
                                value="Test server to serve TODOResourceType resource(s) for the test patient."/>
        </nts:include>

        <nts:include value="assert.response.numResources"
                     scope="common"
                     resource="TODOResourceType"
                     count="TODO-expected-count"/>

        <!-- Optional: enable when content validation is part of this role/test variant. -->
        <!-- <nts:contentAsserts href="resources/TODO-resource.xml" nts:in-targets="CheckContent"/> -->
    </test>

    <test id="02-serve-TODO-resource-read">
        <name value="02 - Serve TODO-resource read"/>
        <description value="Make a specific TODO-resource available for a FHIR read from the test system."/>

        <nts:include value="test.server.successfulRead"
                     scope="common"
                     resource="TODOResourceType"
                     params="/TODO-resource-id"
                     useToken="true"/>
    </test>
</TestScript>
