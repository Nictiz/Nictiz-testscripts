<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="server">
   <id value="mp9-t-rec-mg-MTD-03-x"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-rec-mg-MTD-03-x"/>
   <title value="Scenario 3.x"/>
   <description value="Receive Medication data MTD building blocks for patient C van de XXX_Voortman&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_medicatiegegevens_ontvangen_MTD&#xA;&#xA;Original description:&#xA;TEST Medicatiegegevens MTD Scenarioset 3"/>
   <nts:fixture id="mgsets-mp-smg-tst-MTD-Scenarioset3-v30"
                href="fixtures/mgsets-mp-smg-tst-MTD-Scenarioset3-v30.{$_FORMAT}"/>
   <nts:includeDateT value="yes"/>
   <test id="mp9-t-rec-mg-MTD-03-x-01">
      <name value="Scenario 3.x"/>
      <description value="Receive Medication data MTD resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test server to handle a Bundle of type transaction."/>
            <contentType value="{$_FORMAT}"/>
            <destination value="1"/>
            <origin value="1"/>
            <requestHeader>
               <field value="Prefer"/>
               <value value="return=representation"/>
            </requestHeader>
            <sourceId value="mgsets-mp-smg-tst-MTD-Scenarioset3-v30"/>
         </operation>
      </action>
      <nts:include value="assert.response.success" scope="common"/>
      <nts:include value="assert.response.bundleContent"
                   scope="common"
                   bundleType="transaction-response"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationAdministration"
                   count="9"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="4"/>
   </test>
   <test id="mp9-t-rec-mg-MTD-03-x-identification">
      <name value="Resource identification"/>
      <description value="Checks if all resources specified by the scenario can be identified unambiguously."/>
      <action>
         <assert>
            <description value="Confirm that the response Bundle contains 1 Medication resource that contains code '2202182|urn:oid:2.16.840.1.113883.2.4.4.7' (AMLODIPINE PCH TABLET 5MG (ALS BESILAAT))"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.7' and code = '2202182')).count() = 1"/>
            <sourceId value="transaction-response"/>
            <warningOnly value="false"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the response Bundle contains 1 Medication resource that contains code '1163094|urn:oid:2.16.840.1.113883.2.4.4.7' (PANTOZOL TABLET MSR 20MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.7' and code = '1163094')).count() = 1"/>
            <sourceId value="transaction-response"/>
            <warningOnly value="false"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the response Bundle contains 1 Medication resource that contains code '603678|urn:oid:2.16.840.1.113883.2.4.4.7' (PROPRANOLOL HCL SANDOZ TABLET 80MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.7' and code = '603678')).count() = 1"/>
            <sourceId value="transaction-response"/>
            <warningOnly value="false"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the response Bundle contains 1 Medication resource that contains code '1089838|urn:oid:2.16.840.1.113883.2.4.4.7' (TRIMETHOPRIM CF TABLET 300MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.7' and code = '1089838')).count() = 1"/>
            <sourceId value="transaction-response"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
</TestScript>
