<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="../../../general/schematron/NictizTestScript.sch" type="application/xml" schematypens="http://purl.oclc.org/dsdl/schematron"?>
<nts:component xmlns="http://hl7.org/fhir" xmlns:nts="http://nictiz.nl/xsl/testscript">
    <nts:parameter name="warningOnly" value="false"/>
    
    <action xmlns="http://hl7.org/fhir">
        <assert>
            <description value="Check that at least one PractitionerRole in the transaction Bundle contains telecom.value."/>        
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is PractitionerRole).telecom.where(value.exists()).exists()"/>
            <warningOnly value="{$warningOnly}"/>
        </assert>
    </action>
</nts:component>