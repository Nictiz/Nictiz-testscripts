            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.7' and code = '1137891')).count() = 1"/>
            <sourceId value="transaction-request"/>
            <warningOnly value="false"/>
