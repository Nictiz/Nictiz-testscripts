<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-t-sen-mg-TA-03-x"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-sen-mg-TA-03-x"/>
   <title value="Scenario 3.x"/>
   <description value="Send Medication data TA building blocks for patient C van de XXX_Voortman&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_medicatiegegevens_sturen_TA&#xA;&#xA;Original description:&#xA;TEST Medicatiegegevens TA Scenarioset 3 (Staken Wijzigen)"/>
   <variable>
      <name value="patient-id"/>
      <sourceId value="transaction-response"/>
      <expression value="entry.response.location.value.where(startsWith('Patient/')).first().substringAfter('Patient/').substringBefore('/_history').substringBefore('/')"/>
   </variable>
   <nts:fixture id="mgsets-mp-smg-tst-TA-Scenarioset3-v30-all"
                href="fixtures/mgsets-mp-smg-tst-TA-Scenarioset3-v30.xml"/>
   <nts:fixture id="mgsets-mp-smg-tst-TA-Scenarioset3-v30"
                href="fixtures/mgsets-mp-smg-tst-TA-Scenarioset3-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-t-sen-mg-TA-03-x-01">
      <name value="Scenario 3.x"/>
      <description value="Send Medication data TA resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response"/>
            <sourceId value="mgsets-mp-smg-tst-TA-Scenarioset3-v30-all"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationDispense"
                   count="25"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="12"/>
   </test>
   <teardown>
      <nts:include value="teardown-deletePatient" scope="project"/>
   </teardown>
</TestScript>
