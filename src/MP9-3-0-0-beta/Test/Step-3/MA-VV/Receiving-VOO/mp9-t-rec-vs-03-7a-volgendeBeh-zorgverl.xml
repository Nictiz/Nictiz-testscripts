<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="server">
   <id value="mp9-t-rec-vs-03-7a-volgendeBeh-zorgverl"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-rec-vs-03-7a-volgendeBeh-zorgverl"/>
   <title value="Scenario 3.7a - volgendeBeh-zorgverl"/>
   <description value="Receive Medication prescription volgendeBeh-zorgverl building blocks for patient C van de XXX_Voortman&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_voorschrift_ontvangen&#xA;&#xA;Original description:&#xA;TEST Scenarioset 3 (initieren scenario) VolgendeBehandelaar met Zorgverlener&#xA;Benodigd voor scenario 3.7b "/>
   <nts:fixture id="mv-mp-vo-tst-3-7a-volgendeBeh-zorgverl-v30"
                href="fixtures/mv-mp-vo-tst-3-7a-volgendeBeh-zorgverl-v30.{$_FORMAT}"/>
   <nts:includeDateT value="yes"/>
   <test id="mp9-t-rec-vs-03-7a-volgendeBeh-zorgverl-01">
      <name value="Scenario 3.7a"/>
      <description value="Receive Medication prescription volgendeBeh-zorgverl resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test server to handle a Bundle of type transaction."/>
            <contentType value="{$_FORMAT}"/>
            <destination value="1"/>
            <origin value="1"/>
            <requestHeader>
               <field value="Prefer"/>
               <value value="return=representation"/>
            </requestHeader>
            <sourceId value="mv-mp-vo-tst-3-7a-volgendeBeh-zorgverl-v30"/>
         </operation>
      </action>
      <nts:include value="assert.response.success" scope="common"/>
      <nts:include value="assert.response.bundleContent"
                   scope="common"
                   bundleType="transaction-response"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationRequest"
                   count="2"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
   <test id="mp9-t-rec-vs-03-7a-volgendeBeh-zorgverl-identification">
      <name value="Resource identification"/>
      <description value="Checks if all resources specified by the scenario can be identified unambiguously."/>
      <action>
         <assert>
            <description value="Confirm that the response Bundle contains 1 Medication resource that contains code '105678|urn:oid:2.16.840.1.113883.2.4.4.10' (APIXABAN TABLET 5MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.10' and code = '105678')).count() = 1"/>
            <sourceId value="transaction-response"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
</TestScript>
