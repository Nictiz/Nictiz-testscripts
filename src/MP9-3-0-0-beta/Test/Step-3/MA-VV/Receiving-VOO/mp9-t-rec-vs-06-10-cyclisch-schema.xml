<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="server">
   <id value="mp9-t-rec-vs-06-10-cyclisch-schema"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-rec-vs-06-10-cyclisch-schema"/>
   <title value="Scenario 6.10 - cyclisch-schema"/>
   <description value="Receive Medication prescription cyclisch-schema building blocks for patient G. XXX_Hemsbergen&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_voorschrift_ontvangen&#xA;&#xA;Original description:&#xA;TEST Scenarioset 6 Cyclisch schema&#xA;Cyclisch schema "/>
   <f:variable xmlns:f="http://hl7.org/fhir">
      <f:name value="patient-id"/>
      <f:sourceId value="transaction-response-fixture"/>
      <f:expression value="Bundle.entry.response.where(location.startsWith('Patient/')).location.first().substring(8).substringBefore('/_history')"/>
   </f:variable>
   <nts:fixture id="mv-mp-vo-tst-6-10-cyclisch-schema-v30"
                href="fixtures/mv-mp-vo-tst-6-10-cyclisch-schema-v30.{$_FORMAT}"/>
   <nts:includeDateT value="yes"/>
   <test id="mp9-t-rec-vs-06-10-cyclisch-schema-01">
      <name value="Scenario 6.10"/>
      <description value="Receive Medication prescription cyclisch-schema resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test server to handle a Bundle of type transaction."/>
            <contentType value="{$_FORMAT}"/>
            <destination value="1"/>
            <origin value="1"/>
            <requestHeader>
               <field value="Prefer"/>
               <value value="return=representation"/>
            </requestHeader>
            <sourceId value="mv-mp-vo-tst-6-10-cyclisch-schema-v30"/>
         </operation>
      </action>
      <nts:include value="assert.response.success" scope="common"/>
      <nts:include value="assert.response.bundleContent"
                   scope="common"
                   bundleType="transaction-response"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationRequest"
                   count="2"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
</TestScript>
