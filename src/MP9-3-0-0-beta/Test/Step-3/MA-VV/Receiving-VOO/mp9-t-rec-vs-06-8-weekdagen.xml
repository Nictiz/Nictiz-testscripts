<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="server">
   <id value="mp9-t-rec-vs-06-8-weekdagen"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-rec-vs-06-8-weekdagen"/>
   <title value="Scenario 6.8 - weekdagen"/>
   <description value="Receive Medication prescription weekdagen building blocks for patient G. XXX_Hemsbergen&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_voorschrift_ontvangen&#xA;&#xA;Original description:&#xA;TEST Scenarioset 6 Weekdagen&#xA;Weekdagen "/>
   <nts:fixture id="mv-mp-vo-tst-6-8-weekdagen-v30"
                href="fixtures/mv-mp-vo-tst-6-8-weekdagen-v30.{$_FORMAT}"/>
   <nts:includeDateT value="yes"/>
   <test id="mp9-t-rec-vs-06-8-weekdagen-01">
      <name value="Scenario 6.8"/>
      <description value="Receive Medication prescription weekdagen resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test server to handle a Bundle of type transaction."/>
            <contentType value="{$_FORMAT}"/>
            <destination value="1"/>
            <origin value="1"/>
            <requestHeader>
               <field value="Prefer"/>
               <value value="return=representation"/>
            </requestHeader>
            <sourceId value="mv-mp-vo-tst-6-8-weekdagen-v30"/>
         </operation>
      </action>
      <nts:include value="assert.response.success" scope="common"/>
      <nts:include value="assert.response.bundleContent"
                   scope="common"
                   bundleType="transaction-response"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationRequest"
                   count="2"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
   <test id="mp9-t-rec-vs-06-8-weekdagen-identification">
      <name value="Resource identification"/>
      <description value="Checks if all resources specified by the scenario can be identified unambiguously."/>
      <action>
         <assert>
            <description value="Confirm that the response Bundle contains 1 Medication resource that contains code '55050|urn:oid:2.16.840.1.113883.2.4.4.10' (IMIQUIMOD 50MG/G CREME)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.10' and code = '55050')).count() = 1"/>
            <sourceId value="transaction-response"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
</TestScript>
