   <name value="mp9-t-sen-vs-06-15-zonodig"/>
   <title value="Scenario 6.15 - zonodig"/>
   <description value="Send Medication prescription zonodig building blocks for patient G. XXX_Hemsbergen&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_voorschrift_sturen&#xA;&#xA;Original description:&#xA;TEST Scenarioset 6 Zo nodig&#xA;Zo nodig "/>
   <variable>
