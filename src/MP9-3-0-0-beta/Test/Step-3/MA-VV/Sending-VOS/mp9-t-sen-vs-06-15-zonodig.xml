      <expression value="entry.response.location.value.where(startsWith('Patient/')).first().substringAfter('Patient/').substringBefore('/_history').substringBefore('/')"/>
   </variable>
   <nts:fixture id="mv-mp-vo-tst-6-15-zonodig-v30-all"
                href="fixtures/mv-mp-vo-tst-6-15-zonodig-v30.xml"/>
   <nts:fixture id="mv-mp-vo-tst-6-15-zonodig-v30"
                href="fixtures/mv-mp-vo-tst-6-15-zonodig-v30.xml"
