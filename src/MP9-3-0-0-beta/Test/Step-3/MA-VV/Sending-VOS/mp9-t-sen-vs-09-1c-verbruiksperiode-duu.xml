<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-t-sen-vs-09-1c-verbruiksperiode-duu"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-sen-vs-09-1c-verbruiksperiode-duu"/>
   <title value="Scenario 9.1c - verbruiksperiode-duur"/>
   <description value="Send Medication prescription verbruiksperiode-duur building blocks for patient M. XXX_Nederveen&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_voorschrift_sturen&#xA;&#xA;Original description:&#xA;TEST Scenarioset 9 Verbruiksperiode duur (dagen)&#xA;Logistieke verbruiksperiode "/>
   <variable>
      <name value="patient-id"/>
      <sourceId value="transaction-response"/>
      <expression value="entry.response.location.where($this.startsWith('Patient/')).first().split('/')[1]"/>
   </variable>
   <nts:fixture id="mv-mp-vo-tst-9-1c-verbruiksperiode-duur-v30-all"
                href="fixtures/mv-mp-vo-tst-9-1c-verbruiksperiode-duur-v30.xml"/>
   <nts:fixture id="mv-mp-vo-tst-9-1c-verbruiksperiode-duur-v30"
                href="fixtures/mv-mp-vo-tst-9-1c-verbruiksperiode-duur-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-t-sen-vs-09-1c-verbruiksperiode-duu-01">
      <name value="Scenario 9.1c"/>
      <description value="Send Medication prescription verbruiksperiode-duur resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response"/>
            <sourceId value="mv-mp-vo-tst-9-1c-verbruiksperiode-duur-v30-all"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationRequest"
                   count="2"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
   <test id="mp9-t-sen-vs-09-1c-verbruiksperiode-duu-identification">
      <name value="Resource identification"/>
      <description value="Checks if all resources specified by the scenario can be identified unambiguously."/>
      <action>
         <assert>
            <description value="Confirm that the request Bundle contains 1 Medication resource that contains code '67903|urn:oid:2.16.840.1.113883.2.4.4.10' (PARACETAMOL 500MG TABLET)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.10' and code = '67903')).count() = 1"/>
            <sourceId value="transaction-request"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
   <teardown>
      <nts:include value="teardown-deletePatient" scope="project"/>
   </teardown>
</TestScript>
