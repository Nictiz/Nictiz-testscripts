<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-t-sen-vs-13-1-contact-episode"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-sen-vs-13-1-contact-episode"/>
   <title value="Scenario 13.1 - contact-episode"/>
   <description value="Send Medication prescription contact-episode building blocks for patient H. XXX_Hoek&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_voorschrift_sturen&#xA;&#xA;Original description:&#xA;TEST Scenarioset  13.1 relatie contact episode&#xA;Relatie naar patiëntcontact en zorgepisode "/>
   <variable>
      <name value="patient-id"/>
      <expression value="entry.response.location.where(startsWith($this,'Patient/')).first().substringAfter('Patient/').substringBefore('/_history')"/>
      <sourceId value="transaction-response"/>
   </variable>
   <nts:fixture id="mv-mp-vo-tst-13-1-contact-episode-v30-all"
                href="fixtures/mv-mp-vo-tst-13-1-contact-episode-v30.xml"/>
   <nts:fixture id="mv-mp-vo-tst-13-1-contact-episode-v30"
                href="fixtures/mv-mp-vo-tst-13-1-contact-episode-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-t-sen-vs-13-1-contact-episode-01">
      <name value="Scenario 13.1"/>
      <description value="Send Medication prescription contact-episode resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response"/>
            <sourceId value="mv-mp-vo-tst-13-1-contact-episode-v30-all"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationRequest"
                   count="2"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
   <teardown>
      <nts:include value="teardown-deletePatient" scope="project"/>
   </teardown>
</TestScript>
