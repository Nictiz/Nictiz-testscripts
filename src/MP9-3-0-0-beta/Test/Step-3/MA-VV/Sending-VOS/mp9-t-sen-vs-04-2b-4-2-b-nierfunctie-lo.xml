<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-t-sen-vs-04-2b-4-2-b-nierfunctie-lo"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-sen-vs-04-2b-4-2-b-nierfunctie-lo"/>
   <title value="Scenario 4.2b - 4-2-b-nierfunctie-loinc-zonder-panel"/>
   <description value="Send Medication prescription 4-2-b-nierfunctie-loinc-zonder-panel building blocks for patient E. XXX_Doppen&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_voorschrift_sturen&#xA;&#xA;Original description:&#xA;TEST Scenarioset 4 Nierfunctie Loinc zonder panel&#xA;Medicatievoorschrift, met test op labuitwisseling&amp;nbsp;&amp;nbsp;met LOINC codes "/>
   <variable>
      <name value="patient-id"/>
      <expression value="Bundle.entry.response.where(location.startsWith('Patient/')).location.first().replace('Patient/([0-9A-Za-z\-\.]+)/_history/.*','$1')"/>
      <sourceId value="transaction-response-fixture"/>
   </variable>
   <nts:fixture id="mv-mp-vo-tst-4-2-b-nierfunctie-loinc-zonder-panel-v30-all"
                href="fixtures/mv-mp-vo-tst-4-2-b-nierfunctie-loinc-zonder-panel-v30.xml"/>
   <nts:fixture id="mv-mp-vo-tst-4-2-b-nierfunctie-loinc-zonder-panel-v30"
                href="fixtures/mv-mp-vo-tst-4-2-b-nierfunctie-loinc-zonder-panel-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-t-sen-vs-04-2b-4-2-b-nierfunctie-lo-01">
      <name value="Scenario 4.2b"/>
      <description value="Send Medication prescription 4-2-b-nierfunctie-loinc-zonder-panel resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response-fixture"/>
            <sourceId value="mv-mp-vo-tst-4-2-b-nierfunctie-loinc-zonder-panel-v30-all"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationRequest"
                   count="2"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
   <teardown>
      <variable>
         <name value="patient-id"/>
         <expression value="Bundle.entry.response.where(location.startsWith('Patient/')).location.first().replace('Patient/([0-9A-Za-z\-\.]+)/_history/.*','$1')"/>
         <sourceId value="transaction-response-fixture"/>
      </variable>
      <action>
         <operation>
            <type>
               <system value="http://touchstone.com/fhir/extended-operation-codes"/>
               <code value="purge"/>
            </type>
            <resource value="Patient"/>
            <description value="Delete the Patient and all subsequent Resources that were created during this test."/>
            <destination value="1"/>
            <encodeRequestUrl value="true"/>
            <params value="/$/$purge"/>
         </operation>
      </action>
   </teardown>
</TestScript>
