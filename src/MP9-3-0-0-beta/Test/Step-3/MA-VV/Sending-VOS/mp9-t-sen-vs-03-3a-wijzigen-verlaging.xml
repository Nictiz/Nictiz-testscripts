<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-t-sen-vs-03-3a-wijzigen-verlaging"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-sen-vs-03-3a-wijzigen-verlaging"/>
   <title value="Scenario 3.3a - wijzigen-verlaging"/>
   <description value="Send Medication prescription wijzigen-verlaging building blocks for patient C van de XXX_Voortman&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_voorschrift_sturen&#xA;&#xA;Original description:&#xA;TEST Scenarioset 3 (initieren scenario) Wijzigen (verlaging)&#xA;Benodigd voor scenario 3.3b "/>
   <variable>
      <name value="patient-id"/>
      <sourceId value="transaction-response"/>
      <expression value="entry.response.location.where($this.startsWith('Patient/')).first().split('/')[1]"/>
   </variable>
   <nts:fixture id="mv-mp-vo-tst-3-3a-wijzigen-verlaging-v30-all"
                href="fixtures/mv-mp-vo-tst-3-3a-wijzigen-verlaging-v30.xml"/>
   <nts:fixture id="mv-mp-vo-tst-3-3a-wijzigen-verlaging-v30"
                href="fixtures/mv-mp-vo-tst-3-3a-wijzigen-verlaging-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-t-sen-vs-03-3a-wijzigen-verlaging-01">
      <name value="Scenario 3.3a"/>
      <description value="Send Medication prescription wijzigen-verlaging resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response"/>
            <sourceId value="mv-mp-vo-tst-3-3a-wijzigen-verlaging-v30-all"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationRequest"
                   count="2"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
   <test id="mp9-t-sen-vs-03-3a-wijzigen-verlaging-identification">
      <name value="Resource identification"/>
      <description value="Checks if all resources specified by the scenario can be identified unambiguously."/>
      <action>
         <assert>
            <description value="Confirm that the request Bundle contains 1 Medication resource that contains code '42293|urn:oid:2.16.840.1.113883.2.4.4.10' (FERROFUMARAAT TABLET 200MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.10' and code = '42293')).count() = 1"/>
            <sourceId value="transaction-request"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
   <teardown>
      <nts:include value="teardown-deletePatient" scope="project"/>
   </teardown>
</TestScript>
