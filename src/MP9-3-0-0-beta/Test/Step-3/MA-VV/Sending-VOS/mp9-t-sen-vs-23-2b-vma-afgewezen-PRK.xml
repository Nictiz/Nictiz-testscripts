<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-t-sen-vs-23-2b-vma-afgewezen-PRK"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-sen-vs-23-2b-vma-afgewezen-PRK"/>
   <title value="Scenario 23.2b - vma-afgewezen-PRK"/>
   <description value="Send Medication prescription vma-afgewezen-PRK building blocks for patient K. XXX_Wieling&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_voorschrift_sturen&#xA;&#xA;Original description:&#xA;TEST Scenarioset 23.2b voorschrift t.b.v. VMA&#xA;&lt;span class=&#34;xforms-group xforms-group-appearance-full&#34; id=&#34;main-ui&#34;&gt;&lt;span class=&#34;xforms-group&#34; id=&#34;xf-103&#34;&gt;&lt;span class=&#34;fr-accordion-lnf xforms-group&#34; id=&#34;main-accordion≡fr-accordion-group&#34;&gt;&lt;span class=&#34;xforms-group&#34; id=&#34;main-accordion≡xf-177⊙16&#34;&gt;TEST Scenarioset 23.2b voorschrift met laxans t.b.v. Afwijzen VMA o.b.v. voorstel PRK "/>
   <variable>
      <name value="patient-id"/>
      <sourceId value="transaction-response"/>
      <expression value="entry.response.location.where($this.startsWith('Patient/')).first().split('/')[1]"/>
   </variable>
   <nts:fixture id="mv-mp-vo-vsg-tst-23-2b-vma-afgewezen-PRK-v30-all"
                href="fixtures/mv-mp-vo-vsg-tst-23-2b-vma-afgewezen-PRK-v30.xml"/>
   <nts:fixture id="mv-mp-vo-vsg-tst-23-2b-vma-afgewezen-PRK-v30"
                href="fixtures/mv-mp-vo-vsg-tst-23-2b-vma-afgewezen-PRK-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-t-sen-vs-23-2b-vma-afgewezen-PRK-01">
      <name value="Scenario 23.2b"/>
      <description value="Send Medication prescription vma-afgewezen-PRK resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response"/>
            <sourceId value="mv-mp-vo-vsg-tst-23-2b-vma-afgewezen-PRK-v30-all"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationRequest"
                   count="2"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
      <nts:include value="assert-practitionerRoleTelecomExists" scope="project"/>
   </test>
   <test id="mp9-t-sen-vs-23-2b-vma-afgewezen-PRK-identification">
      <name value="Resource identification"/>
      <description value="Checks if all resources specified by the scenario can be identified unambiguously."/>
      <action>
         <assert>
            <description value="Confirm that the request Bundle contains 1 Medication resource that contains code '150002|urn:oid:2.16.840.1.113883.2.4.4.10' (MACROGOL/ZOUTEN PDR V DRANK (PLEINVUE))"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.10' and code = '150002')).count() = 1"/>
            <sourceId value="transaction-request"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
   <teardown>
      <nts:include value="teardown-deletePatient" scope="project"/>
   </teardown>
</TestScript>
