<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-t-sen-mg-VV-07-x"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-sen-mg-VV-07-x"/>
   <title value="Scenario 7.x"/>
   <description value="Send Medication data VV building blocks for patient G. XXX_Hess&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_medicatiegegevens_sturen_VV&#xA;&#xA;Original description:&#xA;TEST Medicatiegegevens VV Scenarioset 7 (Magistraal)"/>
   <variable>
      <name value="patient-id"/>
      <sourceId value="transaction-response"/>
      <expression value="entry.response.location.where($this.startsWith('Patient/')).first().split('/')[1]"/>
   </variable>
   <nts:fixture id="mgsets-mp-smg-tst-VV-Scenarioset7-v30-all"
                href="fixtures/mgsets-mp-smg-tst-VV-Scenarioset7-v30.xml"/>
   <nts:fixture id="mgsets-mp-smg-tst-VV-Scenarioset7-v30"
                href="fixtures/mgsets-mp-smg-tst-VV-Scenarioset7-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-t-sen-mg-VV-07-x-01">
      <name value="Scenario 7.x"/>
      <description value="Send Medication data VV resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response"/>
            <sourceId value="mgsets-mp-smg-tst-VV-Scenarioset7-v30-all"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationRequest"
                   count="4"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="4"/>
   </test>
   <test id="mp9-t-sen-mg-VV-07-x-identification">
      <name value="Resource identification"/>
      <description value="Checks if all resources specified by the scenario can be identified unambiguously."/>
      <action>
         <assert>
            <description value="Confirm that the request Bundle contains 3 Medication resource that contains code 'OTH|http://terminology.hl7.org/CodeSystem/v3-NullFlavor' (overig)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'http://terminology.hl7.org/CodeSystem/v3-NullFlavor' and code = 'OTH')).count() = 3"/>
            <sourceId value="transaction-request"/>
            <warningOnly value="false"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the request Bundle contains 1 Medication resource that contains code '90000001|urn:oid:2.16.840.1.113883.2.4.3.11.9999.77.90000000.1.1111' (Eigen artikel: ureumzalf)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.3.11.9999.77.90000000.1.1111' and code = '90000001')).count() = 1"/>
            <sourceId value="transaction-request"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
   <teardown>
      <nts:include value="teardown-deletePatient" scope="project"/>
   </teardown>
</TestScript>
