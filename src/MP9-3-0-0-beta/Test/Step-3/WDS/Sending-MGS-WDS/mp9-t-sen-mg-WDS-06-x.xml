<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-t-sen-mg-WDS-06-x"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-sen-mg-WDS-06-x"/>
   <title value="Scenario 6.x"/>
   <description value="Send Medication data WDS building blocks for patient M. XXX_Niesing&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_medicatiegegevens_sturen_WDS&#xA;&#xA;Original description:&#xA;TEST Medicatiegegevens WDS Scenarioset 6"/>
   <variable>
      <name value="patient-id"/>
      <expression value="Bundle.entry.response.where(location.startsWith('Patient/')).location.first().replace('Patient/([0-9A-Za-z\-\.]+)/_history/.*','$1')"/>
      <sourceId value="transaction-response-fixture"/>
   </variable>
   <nts:fixture id="mgsets-mp-smg-tst-WDS-Scenarioset6-v30-all"
                href="fixtures/mgsets-mp-smg-tst-WDS-Scenarioset6-v30.xml"/>
   <nts:fixture id="mgsets-mp-smg-tst-WDS-Scenarioset6-v30"
                href="fixtures/mgsets-mp-smg-tst-WDS-Scenarioset6-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-t-sen-mg-WDS-06-x-01">
      <name value="Scenario 6.x"/>
      <description value="Send Medication data WDS resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response-fixture"/>
            <sourceId value="mgsets-mp-smg-tst-WDS-Scenarioset6-v30-all"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationRequest"
                   count="2"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="2"/>
   </test>
   <teardown>
      <variable>
         <name value="patient-id"/>
         <expression value="Bundle.entry.response.where(location.startsWith('Patient/')).location.first().replace('Patient/([0-9A-Za-z\-\.]+)/_history/.*','$1')"/>
         <sourceId value="transaction-response-fixture"/>
      </variable>
      <action>
         <operation>
            <type>
               <system value="http://touchstone.com/fhir/extended-operation-codes"/>
               <code value="purge"/>
            </type>
            <resource value="Patient"/>
            <description value="Delete the Patient and all subsequent Resources that were created during this test."/>
            <destination value="1"/>
            <encodeRequestUrl value="true"/>
            <params value="/$/$purge"/>
         </operation>
      </action>
   </teardown>
</TestScript>
