<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-t-sen-mg-MA-13-x"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-sen-mg-MA-13-x"/>
   <title value="Scenario 13.x"/>
   <description value="Send Medication data MA building blocks for patient H. XXX_Hoek&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_medicatiegegevens_sturen_MA&#xA;&#xA;Original description:&#xA;TEST Medicatiegegevens MA Scenarioset 13"/>
   <variable>
      <name value="patient-id"/>
      <sourceId value="transaction-response-fixture"/>
      <expression value="Bundle.entry.response.where(location.startsWith('Patient/')).location.first().replace('Patient/([0-9A-Za-z\-\.]+)/_history/.*','$1')"/>
   </variable>
   <nts:fixture id="mgsets-mp-smg-tst-MA-Scenario13-v30-all"
                href="fixtures/mgsets-mp-smg-tst-MA-Scenario13-v30.xml"/>
   <nts:fixture id="mgsets-mp-smg-tst-MA-Scenario13-v30"
                href="fixtures/mgsets-mp-smg-tst-MA-Scenario13-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-t-sen-mg-MA-13-x-01">
      <name value="Scenario 13.x"/>
      <description value="Send Medication data MA resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response-fixture"/>
            <sourceId value="mgsets-mp-smg-tst-MA-Scenario13-v30-all"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationRequest"
                   count="1"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
   <teardown>
      <nts:include value="teardown-deletePatient" scope="project"/>
   </teardown>
</TestScript>
