<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-t-sen-avma-nieuwe-medicatie"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-sen-avma-nieuwe-medicatie"/>
   <title value="Scenario nieuwe-medicatie"/>
   <description value="Send Reply proposal medication agreement nieuwe-medicatie building blocks for patient C. XXX_Brugge&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_avma_sturen&#xA;&#xA;Original description:&#xA;TEST AVMA nieuwe medicatie&#xA;Scenarioset: AVMA nieuwe MBH "/>
   <variable>
      <name value="patient-id"/>
      <expression value="Bundle.entry.response.where(location.startsWith('Patient/')).location.first().replace('Patient/([0-9A-Za-z\-\.]+)/_history/.*','$1')"/>
      <sourceId value="transaction-response-fixture"/>
   </variable>
   <nts:fixture id="mp-am-tst-nieuwe-medicatie-v30-all"
                href="fixtures/mp-am-tst-nieuwe-medicatie-v30.xml"/>
   <nts:fixture id="mp-am-tst-nieuwe-medicatie-v30"
                href="fixtures/mp-am-tst-nieuwe-medicatie-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-t-sen-avma-nieuwe-medicatie-01">
      <name value="Scenario nieuwe-medicatie"/>
      <description value="Send Reply proposal medication agreement nieuwe-medicatie resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response-fixture"/>
            <sourceId value="mp-am-tst-nieuwe-medicatie-v30-all"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
   </test>
   <teardown>
      <variable>
         <name value="patient-id"/>
         <expression value="Bundle.entry.response.where(location.startsWith('Patient/')).location.first().replace('Patient/([0-9A-Za-z\-\.]+)/_history/.*','$1')"/>
         <sourceId value="transaction-response-fixture"/>
      </variable>
      <action>
         <operation>
            <type>
               <system value="http://touchstone.com/fhir/extended-operation-codes"/>
               <code value="purge"/>
            </type>
            <resource value="Patient"/>
            <description value="Delete the Patient and all subsequent Resources that were created during this test."/>
            <destination value="1"/>
            <encodeRequestUrl value="true"/>
            <params value="/$/$purge"/>
         </operation>
      </action>
   </teardown>
</TestScript>
