<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-t-sen-vvv-23-6-23.6-vvv-geaccepteer"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-sen-vvv-23-6-23.6-vvv-geaccepteer"/>
   <title value="Scenario 23.6 - 23.6-vvv-geaccepteerdmetwijziging"/>
   <description value="Send Proposal dispense request 23.6-vvv-geaccepteerdmetwijziging building blocks for patient J. van XXX_Reenen&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_vvv_sturen&#xA;&#xA;Original description:&#xA;TEST scenarioset 23.6 VVV&#xA;TEST scenarioset 23.6 VVV: gedeeltelijke overname VVV "/>
   <variable>
      <name value="patient-id"/>
      <sourceId value="transaction-response"/>
      <expression value="entry.response.location.where($this.startsWith('Patient/')).first().split('/')[1]"/>
   </variable>
   <nts:fixture id="mp-vv-tst-23-6-vvv-geaccepteerdmetwijziging-v30-all"
                href="fixtures/mp-vv-tst-23-6-vvv-geaccepteerdmetwijziging-v30.xml"/>
   <nts:fixture id="mp-vv-tst-23-6-vvv-geaccepteerdmetwijziging-v30"
                href="fixtures/mp-vv-tst-23-6-vvv-geaccepteerdmetwijziging-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-t-sen-vvv-23-6-23.6-vvv-geaccepteer-01">
      <name value="Scenario 23.6"/>
      <description value="Send Proposal dispense request 23.6-vvv-geaccepteerdmetwijziging resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response"/>
            <sourceId value="mp-vv-tst-23-6-vvv-geaccepteerdmetwijziging-v30-all"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationRequest"
                   count="1"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
   <test id="mp9-t-sen-vvv-23-6-23.6-vvv-geaccepteer-identification">
      <name value="Resource identification"/>
      <description value="Checks if all resources specified by the scenario can be identified unambiguously."/>
      <action>
         <assert>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is MedicationRequest).where(category.coding.code = '52711000146108').where((( (medication.where($this is CodeableConcept).coding | medication.where($this is Reference).resolve().code.coding).exists(code = '60062') ) and ( (medication.where($this is CodeableConcept).coding | medication.where($this is Reference).resolve().code.coding).exists(code = '114529') ))).count() = 1"/>
            <sourceId value="transaction-request"/>
            <warningOnly value="false"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the request Bundle contains 1 Medication resource that contains code '60062|urn:oid:2.16.840.1.113883.2.4.4.10' (OMEPRAZOL CAPSULE MSR 20MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.10' and code = '60062')).count() = 1"/>
            <sourceId value="transaction-request"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
   <teardown>
      <nts:include value="teardown-deletePatient" scope="project"/>
   </teardown>
</TestScript>
