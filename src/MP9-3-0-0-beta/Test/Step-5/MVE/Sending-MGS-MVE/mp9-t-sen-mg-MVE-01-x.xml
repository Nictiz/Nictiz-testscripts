<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-t-sen-mg-MVE-01-x"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-sen-mg-MVE-01-x"/>
   <title value="Scenario 1.x"/>
   <description value="Send Medication data MVE building blocks for patient C. XXX_Brugge&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_medicatiegegevens_sturen_MVE&#xA;&#xA;Original description:&#xA;TEST Medicatiegegevens MVE Scenarioset 1"/>
   <variable>
      <name value="patient-id"/>
      <sourceId value="transaction-response"/>
      <expression value="entry.response.location.where($this.startsWith('Patient/')).first().split('/')[1]"/>
   </variable>
   <nts:fixture id="mgsets-mp-smg-tst-MVE-Scenarioset1-v30-all"
                href="fixtures/mgsets-mp-smg-tst-MVE-Scenarioset1-v30.xml"/>
   <nts:fixture id="mgsets-mp-smg-tst-MVE-Scenarioset1-v30"
                href="fixtures/mgsets-mp-smg-tst-MVE-Scenarioset1-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-t-sen-mg-MVE-01-x-01">
      <name value="Scenario 1.x"/>
      <description value="Send Medication data MVE resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response"/>
            <sourceId value="mgsets-mp-smg-tst-MVE-Scenarioset1-v30-all"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationDispense"
                   count="2"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
   <test id="mp9-t-sen-mg-MVE-01-x-identification">
      <name value="Resource identification"/>
      <description value="Checks if all resources specified by the scenario can be identified unambiguously."/>
      <action>
         <assert>
            <description value="Confirm that the request Bundle contains 1 Medication resource that contains code '202185|urn:oid:2.16.840.1.113883.2.4.4.7' (ROTER APC TABLET)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.7' and code = '202185')).count() = 1"/>
            <sourceId value="transaction-request"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
   <teardown>
      <nts:include value="teardown-deletePatient" scope="project"/>
   </teardown>
</TestScript>
