<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="server">
   <id value="mp9-t-rec-mg-MVE-09-x"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-rec-mg-MVE-09-x"/>
   <title value="Scenario 9.x"/>
   <description value="Receive Medication data MVE building blocks for patient M. XXX_Nederveen&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_medicatiegegevens_ontvangen_MVE&#xA;&#xA;Original description:&#xA;TEST Medicatiegegevens MVE Scenarioset 9 (diversen MVE)"/>
   <nts:fixture id="mgsets-mp-smg-tst-MVE-Scenarioset9-v30"
                href="fixtures/mgsets-mp-smg-tst-MVE-Scenarioset9-v30.{$_FORMAT}"/>
   <nts:includeDateT value="yes"/>
   <test id="mp9-t-rec-mg-MVE-09-x-01">
      <name value="Scenario 9.x"/>
      <description value="Receive Medication data MVE resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test server to handle a Bundle of type transaction."/>
            <contentType value="{$_FORMAT}"/>
            <destination value="1"/>
            <origin value="1"/>
            <requestHeader>
               <field value="Prefer"/>
               <value value="return=representation"/>
            </requestHeader>
            <sourceId value="mgsets-mp-smg-tst-MVE-Scenarioset9-v30"/>
         </operation>
      </action>
      <nts:include value="assert.response.success" scope="common"/>
      <nts:include value="assert.response.bundleContent"
                   scope="common"
                   bundleType="transaction-response"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationDispense"
                   count="7"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="5"/>
   </test>
   <test id="mp9-t-rec-mg-MVE-09-x-identification">
      <name value="Resource identification"/>
      <description value="Checks if all resources specified by the scenario can be identified unambiguously."/>
      <action>
         <assert>
            <description value="Confirm that the response Bundle contains 1 Medication resource that contains code '1137891|urn:oid:2.16.840.1.113883.2.4.4.7' (ACETYLSALICYLZUUR CARDIO AUROBINDO DISP TABL 80MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.7' and code = '1137891')).count() = 1"/>
            <sourceId value="transaction-response"/>
            <warningOnly value="false"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the response Bundle contains 1 Medication resource that contains code '1127047|urn:oid:2.16.840.1.113883.2.4.4.7' (FUROSEMIDE APOTEX TABLET 40MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.7' and code = '1127047')).count() = 1"/>
            <sourceId value="transaction-response"/>
            <warningOnly value="false"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the response Bundle contains 1 Medication resource that contains code '1101099|urn:oid:2.16.840.1.113883.2.4.4.7' (MIZOLLEN TABLET MGA 10MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.7' and code = '1101099')).count() = 1"/>
            <sourceId value="transaction-response"/>
            <warningOnly value="false"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the response Bundle contains 1 Medication resource that contains code '2842246|urn:oid:2.16.840.1.113883.2.4.4.7' (MODAFINIL FOCUS TABLET 200MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.7' and code = '2842246')).count() = 1"/>
            <sourceId value="transaction-response"/>
            <warningOnly value="false"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the response Bundle contains 1 Medication resource that contains code '768901|urn:oid:2.16.840.1.113883.2.4.4.7' (PARACETAMOL PCH TABLET 500MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.7' and code = '768901')).count() = 1"/>
            <sourceId value="transaction-response"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
</TestScript>
