<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-t-sen-avs-03-3b-wijzigen-verlaging"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-sen-avs-03-3b-wijzigen-verlaging"/>
   <title value="Scenario 3.3b - wijzigen-verlaging"/>
   <description value="Send Prescription processing wijzigen-verlaging building blocks for patient C van de XXX_Voortman&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_afhandelen_voorschrift_sturen&#xA;&#xA;Original description:&#xA;TEST Scenarioset 3 Wijzigen (verlaging)&#xA;Wijziging toedieningsafspraak, met verlaging wijziging (stop-ta + nieuwe ta) zonder MVE&lt;br style=&#34;font-family: sans-serif; font-size: 14px; background-color: #ffffff;&#34;&gt;LET OP: wijziging toedieningsafspraak van scenario 3.3a "/>
   <variable>
      <name value="patient-id"/>
      <sourceId value="transaction-response"/>
      <expression value="entry.response.location.where($this.startsWith('Patient/')).first().split('/')[1]"/>
   </variable>
   <nts:fixture id="av-mp-va-tst-3-3b-wijzigen-verlaging-v30-all"
                href="fixtures/av-mp-va-tst-3-3b-wijzigen-verlaging-v30.xml"/>
   <nts:fixture id="av-mp-va-tst-3-3b-wijzigen-verlaging-v30"
                href="fixtures/av-mp-va-tst-3-3b-wijzigen-verlaging-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-t-sen-avs-03-3b-wijzigen-verlaging-01">
      <name value="Scenario 3.3b"/>
      <description value="Send Prescription processing wijzigen-verlaging resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response"/>
            <sourceId value="av-mp-va-tst-3-3b-wijzigen-verlaging-v30-all"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationDispense"
                   count="2"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
   <test id="mp9-t-sen-avs-03-3b-wijzigen-verlaging-identification">
      <name value="Resource identification"/>
      <description value="Checks if all resources specified by the scenario can be identified unambiguously."/>
      <action>
         <assert>
            <description value="Confirm that the request Bundle contains 1 Medication resource that contains code '869244|urn:oid:2.16.840.1.113883.2.4.4.7' (FERROFUMARAAT TEVA TABLET 200MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.7' and code = '869244')).count() = 1"/>
            <sourceId value="transaction-request"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
   <teardown>
      <nts:include value="teardown-deletePatient" scope="project"/>
   </teardown>
</TestScript>
