<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-t-sen-avs-03-4a-onderbreken"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-sen-avs-03-4a-onderbreken"/>
   <title value="Scenario 3.4a - onderbreken"/>
   <description value="Send Prescription processing onderbreken building blocks for patient C van de XXX_Voortman&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_afhandelen_voorschrift_sturen&#xA;&#xA;Original description:&#xA;TEST Scenarioset 3 (initieren scenario) Onderbreken &#xA;Benodigd voor scenario 3.4b "/>
   <variable>
      <name value="patient-id"/>
      <sourceId value="transaction-response-fixture"/>
      <expression value="Bundle.entry.response.location                                    .where(startsWith($this,'Patient/'))                                    .first()                                    .substring(8)                                    .substringBefore('/_history')"/>
   </variable>
   <nts:fixture id="av-mp-va-tst-3-4a-onderbreken-v30"
                href="fixtures/av-mp-va-tst-3-4a-onderbreken-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-t-sen-avs-03-4a-onderbreken-01">
      <name value="Scenario 3.4a"/>
      <description value="Send Prescription processing onderbreken resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response-fixture"/>
            <sourceId value="av-mp-va-tst-3-4a-onderbreken-v30"
                      nts:in-targets="Nictiz-intern"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationDispense"
                   count="2"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
   <teardown>
      <nts:include value="teardown-deletePatient" scope="project"/>
   </teardown>
</TestScript>
