<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="server">
   <id value="mp9-t-rec-avs-01-1-ingangsdatum-einddat"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-rec-avs-01-1-ingangsdatum-einddat"/>
   <title value="Scenario 1.1 - ingangsdatum-einddatum"/>
   <description value="Receive Prescription processing ingangsdatum-einddatum building blocks for patient C. XXX_Brugge&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_afhandelen_voorschrift_ontvangen&#xA;&#xA;Original description:&#xA;TEST Scenarioset 1 ingangsdatum einddatum&#xA;Afhandelen medicatievoorschrift met een toedieningsafspraak gebruiksperiode ingangsdatum en einddatum "/>
   <nts:fixture id="av-mp-va-tst-1-1-ingangsdatum-einddatum-v30"
                href="fixtures/av-mp-va-tst-1-1-ingangsdatum-einddatum-v30.{$_FORMAT}"/>
   <nts:includeDateT value="yes"/>
   <test id="mp9-t-rec-avs-01-1-ingangsdatum-einddat-01">
      <name value="Scenario 1.1"/>
      <description value="Receive Prescription processing ingangsdatum-einddatum resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test server to handle a Bundle of type transaction."/>
            <contentType value="{$_FORMAT}"/>
            <destination value="1"/>
            <origin value="1"/>
            <requestHeader>
               <field value="Prefer"/>
               <value value="return=representation"/>
            </requestHeader>
            <sourceId value="av-mp-va-tst-1-1-ingangsdatum-einddatum-v30"/>
         </operation>
      </action>
      <nts:include value="assert.response.success" scope="common"/>
      <nts:include value="assert.response.bundleContent"
                   scope="common"
                   bundleType="transaction-response"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationDispense"
                   count="2"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
   <test id="mp9-t-rec-avs-01-1-ingangsdatum-einddat-identification">
      <name value="Resource identification"/>
      <description value="Checks if all resources specified by the scenario can be identified unambiguously."/>
      <action>
         <assert>
            <description value="Confirm that the response Bundle contains 1 Medication resource that contains code '2115468|urn:oid:2.16.840.1.113883.2.4.4.7' (METOCLOPRAMIDE HCL ACCORD TABLET 10MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.7' and code = '2115468')).count() = 1"/>
            <sourceId value="transaction-response"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
</TestScript>
