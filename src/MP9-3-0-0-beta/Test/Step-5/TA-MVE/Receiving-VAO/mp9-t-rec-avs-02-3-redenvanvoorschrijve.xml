<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="server">
   <id value="mp9-t-rec-avs-02-3-redenvanvoorschrijve"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-rec-avs-02-3-redenvanvoorschrijve"/>
   <title value="Scenario 2.3 - redenvanvoorschrijven"/>
   <description value="Receive Prescription processing redenvanvoorschrijven building blocks for patient C. XXX_Coenen&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_afhandelen_voorschrift_ontvangen&#xA;&#xA;Original description:&#xA;TEST Scenarioset 2 Reden van voorschrijven&#xA;Reden van voorschrijven (TA) "/>
   <f:variable xmlns:f="http://hl7.org/fhir">
      <f:name value="patient-id"/>
      <f:sourceId value="transaction-response-fixture"/>
      <f:expression value="Bundle.entry.response.where(location.startsWith('Patient/')).location.first().substring(8).substringBefore('/_history')"/>
   </f:variable>
   <nts:fixture id="av-mp-va-tst-2-3-redenvanvoorschrijven-v30"
                href="fixtures/av-mp-va-tst-2-3-redenvanvoorschrijven-v30.{$_FORMAT}"/>
   <nts:includeDateT value="yes"/>
   <test id="mp9-t-rec-avs-02-3-redenvanvoorschrijve-01">
      <name value="Scenario 2.3"/>
      <description value="Receive Prescription processing redenvanvoorschrijven resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test server to handle a Bundle of type transaction."/>
            <contentType value="{$_FORMAT}"/>
            <destination value="1"/>
            <origin value="1"/>
            <requestHeader>
               <field value="Prefer"/>
               <value value="return=representation"/>
            </requestHeader>
            <sourceId value="av-mp-va-tst-2-3-redenvanvoorschrijven-v30"/>
         </operation>
      </action>
      <nts:include value="assert.response.success" scope="common"/>
      <nts:include value="assert.response.bundleContent"
                   scope="common"
                   bundleType="transaction-response"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationDispense"
                   count="2"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
</TestScript>
