<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-t-sen-vma-nieuwe-medicatie"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-sen-vma-nieuwe-medicatie"/>
   <title value="Scenario nieuwe-medicatie"/>
   <description value="Send Proposal medication agreement nieuwe-medicatie building blocks for patient C. XXX_Brugge&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_vma_sturen&#xA;&#xA;Original description:&#xA;TEST VMA nieuwe medicatie&#xA;Scenarioset: VMA nieuwe MBH "/>
   <variable>
      <name value="patient-id"/>
      <sourceId value="transaction-response"/>
      <expression value="entry.response.location.where($this.startsWith('Patient/')).first().split('/')[1]"/>
   </variable>
   <nts:fixture id="mp-vm-tst-nieuwe-medicatie-v30-all"
                href="fixtures/mp-vm-tst-nieuwe-medicatie-v30.xml"/>
   <nts:fixture id="mp-vm-tst-nieuwe-medicatie-v30"
                href="fixtures/mp-vm-tst-nieuwe-medicatie-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-t-sen-vma-nieuwe-medicatie-01">
      <name value="Scenario nieuwe-medicatie"/>
      <description value="Send Proposal medication agreement nieuwe-medicatie resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response"/>
            <sourceId value="mp-vm-tst-nieuwe-medicatie-v30-all"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationRequest"
                   count="1"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
   <test id="mp9-t-sen-vma-nieuwe-medicatie-identification">
      <name value="Resource identification"/>
      <description value="Checks if all resources specified by the scenario can be identified unambiguously."/>
      <action>
         <assert>
            <description value="Confirm that the request Bundle contains 1 Medication resource that contains code '33154|urn:oid:2.16.840.1.113883.2.4.4.10' (IBUPROFEN 800MG TABLET MGA)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.10' and code = '33154')).count() = 1"/>
            <sourceId value="transaction-request"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
   <teardown>
      <nts:include value="teardown-deletePatient" scope="project"/>
   </teardown>
</TestScript>
