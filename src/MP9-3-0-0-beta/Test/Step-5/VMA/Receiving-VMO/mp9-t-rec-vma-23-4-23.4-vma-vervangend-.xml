<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="server">
   <id value="mp9-t-rec-vma-23-4-23.4-vma-vervangend-"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-rec-vma-23-4-23.4-vma-vervangend-"/>
   <title value="Scenario 23.4 - 23.4-vma-vervangend-middel"/>
   <description value="Receive Proposal medication agreement 23.4-vma-vervangend-middel building blocks for patient J. van de XXX_Knaap&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_vma_ontvangen&#xA;&#xA;Original description:&#xA;TEST scenarioset 23.4 VMA&#xA;TEST scenarioset 23.4 VMA: Vervangend middel VMA "/>
   <nts:fixture id="mp-vm-tst-23-4-vma-vervangend-middel-v30"
                href="fixtures/mp-vm-tst-23-4-vma-vervangend-middel-v30.{$_FORMAT}"/>
   <nts:includeDateT value="yes"/>
   <test id="mp9-t-rec-vma-23-4-23.4-vma-vervangend--01">
      <name value="Scenario 23.4"/>
      <description value="Receive Proposal medication agreement 23.4-vma-vervangend-middel resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test server to handle a Bundle of type transaction."/>
            <contentType value="{$_FORMAT}"/>
            <destination value="1"/>
            <origin value="1"/>
            <requestHeader>
               <field value="Prefer"/>
               <value value="return=representation"/>
            </requestHeader>
            <sourceId value="mp-vm-tst-23-4-vma-vervangend-middel-v30"/>
         </operation>
      </action>
      <nts:include value="assert.response.success" scope="common"/>
      <nts:include value="assert.response.bundleContent"
                   scope="common"
                   bundleType="transaction-response"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationRequest"
                   count="1"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
   <test id="mp9-t-rec-vma-23-4-23.4-vma-vervangend--identification">
      <name value="Resource identification"/>
      <description value="Checks if all resources specified by the scenario can be identified unambiguously."/>
      <action>
         <assert>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is MedicationRequest).where((( (medication.where($this is CodeableConcept).coding | medication.where($this is Reference).resolve().code.coding).exists(code = '80349') ) and ( (medication.where($this is CodeableConcept).coding | medication.where($this is Reference).resolve().code.coding).exists(code = '125156') ))).count() = 1"/>
            <sourceId value="transaction-response"/>
            <warningOnly value="false"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the response Bundle contains 1 Medication resource that contains code '80349|urn:oid:2.16.840.1.113883.2.4.4.10' (KETOCONAZOL SHAMPOO 20MG/G)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.10' and code = '80349')).count() = 1"/>
            <sourceId value="transaction-response"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
</TestScript>
