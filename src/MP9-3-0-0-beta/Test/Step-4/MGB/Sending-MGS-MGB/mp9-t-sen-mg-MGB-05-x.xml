<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-t-sen-mg-MGB-05-x"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-t-sen-mg-MGB-05-x"/>
   <title value="Scenario 5.x"/>
   <description value="Send Medication data MGB building blocks for patient M. XXX_Raamsdonk&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_testgegevens_medicatiegegevens_sturen_MGB&#xA;&#xA;Original description:&#xA;TEST Medicatiegegevens MGB Scenarioset 5"/>
   <variable>
      <name value="patient-id"/>
      <sourceId value="transaction-response"/>
      <expression value="entry.response.location.where($this.startsWith('Patient/')).first().split('/')[1]"/>
   </variable>
   <nts:fixture id="mgsets-mp-smg-tst-MGB-Scenarioset5-v30-all"
                href="fixtures/mgsets-mp-smg-tst-MGB-Scenarioset5-v30.xml"/>
   <nts:fixture id="mgsets-mp-smg-tst-MGB-Scenarioset5-v30"
                href="fixtures/mgsets-mp-smg-tst-MGB-Scenarioset5-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-t-sen-mg-MGB-05-x-01">
      <name value="Scenario 5.x"/>
      <description value="Send Medication data MGB resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response"/>
            <sourceId value="mgsets-mp-smg-tst-MGB-Scenarioset5-v30-all"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationStatement"
                   count="7"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="6"/>
   </test>
   <test id="mp9-t-sen-mg-MGB-05-x-identification">
      <name value="Resource identification"/>
      <description value="Checks if all resources specified by the scenario can be identified unambiguously."/>
      <action>
         <assert>
            <description value="Confirm that the request Bundle contains 1 Medication resource that contains code '1929461|urn:oid:2.16.840.1.113883.2.4.4.7' (PRADAXA CAPSULE 110MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.7' and code = '1929461')).count() = 1"/>
            <sourceId value="transaction-request"/>
            <warningOnly value="false"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the request Bundle contains 1 Medication resource that contains code '1592904|urn:oid:2.16.840.1.113883.2.4.4.7' (VOLTAREN K TABLET OMHULD 12,5MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.7' and code = '1592904')).count() = 1"/>
            <sourceId value="transaction-request"/>
            <warningOnly value="false"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the request Bundle contains 1 Medication resource that contains code '76333|urn:oid:2.16.840.1.113883.2.4.4.10' (HYDROCHLOORTHIAZIDE TABLET 12,5MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.where(coding.count() = 2 and coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.10' and code = '76333') and coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.1' and code = '122602'))).count() = 1"/>
            <sourceId value="transaction-request"/>
            <warningOnly value="false"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the request Bundle contains 1 Medication resource that contains code '2530104|urn:oid:2.16.840.1.113883.2.4.4.7' (HYDROCHLOORTHIAZIDE APOTEX TABLET 12,5MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.7' and code = '2530104')).count() = 1"/>
            <sourceId value="transaction-request"/>
            <warningOnly value="false"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the request Bundle contains 1 Medication resource that contains code 'OTH|http://terminology.hl7.org/CodeSystem/v3-NullFlavor' (overig)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'http://terminology.hl7.org/CodeSystem/v3-NullFlavor' and code = 'OTH')).count() = 1"/>
            <sourceId value="transaction-request"/>
            <warningOnly value="false"/>
         </assert>
      </action>
      <action>
         <assert>
            <description value="Confirm that the request Bundle contains 1 Medication resource that contains code '67814|urn:oid:2.16.840.1.113883.2.4.4.10' (SIMVASTATINE TABLET FO 20MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.10' and code = '67814')).count() = 1"/>
            <sourceId value="transaction-request"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
   <teardown>
      <nts:include value="teardown-deletePatient" scope="project"/>
   </teardown>
</TestScript>
