<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="server">
   <id value="mp9-c-rec-vs-02-x"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-c-rec-vs-02-x"/>
   <title value="Scenario 2.x"/>
   <description value="Receive Medication prescription script2 building blocks for patient M. van XXX_Noordman&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_kwalificatie_voorschrift_ontvangen&#xA;&#xA;Original description:&#xA;KWAL script 2&#xA;Kwalificatie script 2: medicatievoorschrift met acenocoumarol. "/>
   <nts:fixture id="mv-mp-vo-kwal-script2-v30"
                href="fixtures/mv-mp-vo-kwal-script2-v30.{$_FORMAT}"/>
   <nts:includeDateT value="yes"/>
   <test id="mp9-c-rec-vs-02-x-01">
      <name value="Scenario 2.x"/>
      <description value="Receive Medication prescription script2 resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test server to handle a Bundle of type transaction."/>
            <contentType value="{$_FORMAT}"/>
            <destination value="1"/>
            <origin value="1"/>
            <requestHeader>
               <field value="Prefer"/>
               <value value="return=representation"/>
            </requestHeader>
            <sourceId value="mv-mp-vo-kwal-script2-v30"/>
         </operation>
      </action>
      <nts:include value="assert.response.success" scope="common"/>
      <nts:include value="assert.response.bundleContent"
                   scope="common"
                   bundleType="transaction-response"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationRequest"
                   count="2"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
   <test id="mp9-c-rec-vs-02-x-identification">
      <name value="Resource identification"/>
      <description value="Checks if all resources specified by the scenario can be identified unambiguously."/>
      <action>
         <assert>
            <description value="Confirm that the response Bundle contains 1 Medication resource that contains code '7323|urn:oid:2.16.840.1.113883.2.4.4.10' (ACENOCOUMAROL TABLET 1MG)"/>
            <direction value="request"/>
            <expression value="Bundle.entry.resource.where($this is Medication).where(code.coding.exists(system = 'urn:oid:2.16.840.1.113883.2.4.4.10' and code = '7323')).count() = 1"/>
            <sourceId value="transaction-response"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
</TestScript>
