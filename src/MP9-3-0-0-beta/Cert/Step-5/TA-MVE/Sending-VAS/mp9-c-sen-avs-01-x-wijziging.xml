<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-c-sen-avs-01-x-wijziging"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-c-sen-avs-01-x-wijziging"/>
   <title value="Scenario 1.x - wijziging"/>
   <description value="Send Prescription processing script1-wijziging building blocks for patient P. XXX_Schut&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_kwalificatie_afhandelen_voorschrift_sturen&#xA;&#xA;Original description:&#xA;KWAL script 1 - Wijziging&#xA;Kwalificatie script 1 - Wijziging: afhandelen medicatievoorschrift met wijziging over chemotherapie.&#xA;Let op: wijziging op basis van kwalificatie script 1 "/>
   <variable>
      <name value="patient-id"/>
      <sourceId value="transaction-response"/>
      <expression value="entry.response.location.where(startsWith($this,'Patient/')).first().substringAfter('Patient/').substringBefore('/_history')"/>
   </variable>
   <nts:fixture id="av-mp-va-kwal-script1-wijziging-v30-all"
                href="fixtures/av-mp-va-kwal-script1-wijziging-v30.xml"/>
   <nts:fixture id="av-mp-va-kwal-script1-wijziging-v30"
                href="fixtures/av-mp-va-kwal-script1-wijziging-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-c-sen-avs-01-x-wijziging-01">
      <name value="Scenario 1.x"/>
      <description value="Send Prescription processing script1-wijziging resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response"/>
            <sourceId value="av-mp-va-kwal-script1-wijziging-v30-all"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationDispense"
                   count="3"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
   <teardown>
      <nts:include value="teardown-deletePatient" scope="project"/>
   </teardown>
</TestScript>
