<TestScript xmlns="http://hl7.org/fhir"
            xmlns:nts="http://nictiz.nl/xsl/testscript"
            nts:scenario="client">
   <id value="mp9-c-sen-avs-05-x"/>
   <version value="r4-mp9-3.0.0"/>
   <name value="mp9-c-sen-avs-05-x"/>
   <title value="Scenario 5.x"/>
   <description value="Send Prescription processing script5 building blocks for patient J. de XXX_Luzac&#xA;&#xA;For more info:&#xA;https://informatiestandaarden.nictiz.nl/wiki/mp:V3.0.0_kwalificatie_afhandelen_voorschrift_sturen&#xA;&#xA;Original description:&#xA;KWAL script 5&#xA;Kwalificatie script 5: afhandelen medicatievoorschriftLet op: benodigd voor kwalificatie script 5 - stop. "/>
   <variable>
      <name value="patient-id"/>
      <sourceId value="transaction-response"/>
      <expression value="Bundle.entry.response.where(location.startsWith('Patient/')).location.first().replace('Patient/([0-9A-Za-z\-\.]+)/_history/.*','$1')"/>
   </variable>
   <nts:fixture id="av-mp-va-kwal-script5-v30-all"
                href="fixtures/av-mp-va-kwal-script5-v30.xml"/>
   <nts:fixture id="av-mp-va-kwal-script5-v30"
                href="fixtures/av-mp-va-kwal-script5-v30.xml"
                nts:in-targets="Nictiz-intern"/>
   <nts:includeDateT value="yes" nts:in-targets="Nictiz-intern"/>
   <test id="mp9-c-sen-avs-05-x-01">
      <name value="Scenario 5.x"/>
      <description value="Send Prescription processing script5 resources in a transaction Bundle"/>
      <action>
         <operation>
            <type>
               <system value="http://terminology.hl7.org/CodeSystem/testscript-operation-codes"/>
               <code value="transaction"/>
            </type>
            <description value="Test client to POST a Bundle of type transaction."/>
            <destination value="1"/>
            <origin value="1"/>
            <responseId value="transaction-response"/>
            <sourceId value="av-mp-va-kwal-script5-v30-all"/>
         </operation>
      </action>
      <nts:include value="test.client.successfulTransaction" scope="common"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="MedicationDispense"
                   count="2"/>
      <nts:include value="assert.request.numResources"
                   scope="common"
                   resource="Medication"
                   count="1"/>
   </test>
   <teardown>
      <nts:include value="teardown-deletePatient" scope="project"/>
   </teardown>
</TestScript>
