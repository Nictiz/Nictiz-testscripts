        <nts:contentAsserts href="imm-bznw-test-alg-mix/vi-imm-Vaccination-event-carenetwork-4bfb70a8-6b64-11ec-0000-020000000000.xml" 
            description="contains .vaccineCode.coding.code = ''" 
            discriminator="vaccineCode.where(coding.where(code = ''))" 
