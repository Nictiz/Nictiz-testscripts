    <nts:authToken patientResourceId="nl-core-Patient-vi-AdamAAdamvandeXXX-Bergge"/>
    
    <test id="immunization-search-response">
        <name value="Test scenario 1 - Serve Immunization resource"/>
        <description value="Serve Immunization resource including the patient and performer."/>
        <nts:include value="medmij/test.xis.successfulSearch" scope="common" resource="Immunization" params="?_include=Immunization:patient&amp;_include=Immunization:performer" responseId="fixture-immunization-search-response"/>
        <nts:include value="assert.response.numResources" scope="common" resource="Immunization" count="7" nts:in-targets="#default"/>
        <nts:include value="assert.response.numResources" scope="common" resource="Patient" count="1" nts:in-targets="#default"/>
        <nts:include value="assert.response.numResources" scope="common" resource="Organization" count="2" nts:in-targets="#default"/>
        <!--er worden twee Organizations aangemaakt, maar check of dat terecht is! één lijkt leeg?-->
        <!--komt nergens in voor.. gebruik dit voor de review ada2fhir-->
        
