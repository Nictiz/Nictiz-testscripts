<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="http://hl7.org/fhir/STU3/testscript.sch" type="application/xml" schematypens="http://purl.oclc.org/dsdl/schematron"?>
<TestScript xmlns="http://hl7.org/fhir" xmlns:nts="http://nictiz.nl/xsl/testscript" nts:scenario="client">
    <id value="imm-retrieve-bznw-test-alg-mix"/>
    <version value="R4-imm-2.2.0-alpha.2"/>
    <name value="Immunization - Client - Test Scenario 1.1 - Retrieve Immunization resources of van de XXX_Bergge"/>
    <description value="Scenario 1.1 - Retrieve Immunization resources of van de XXX_Bergge"/>
    <nts:authToken patientResourceId="nl-core-Patient-vi-AdamAAdamvandeXXX-Bergge"/>
    
    <test>
        <name value="Test scenario 1 - Retrieve Immunization resources"/>
        <description value="Query Immunization resource"/>
        <nts:include value="medmij/test.phr.search" scope="common" resource="Immunization"/>
        <nts:include value="canary-assert.response.successfulSearch" scope="common"/>
        <nts:include value="assert.response.numResources" scope="common" resource="Immunization" count="7"/>
        
        <nts:include value="assert.numIdentifier" direction="response" resource="Immunization" count="7"/>
        <nts:include value="assert.numMedicationReference" direction="response" resource="Immunization" count="7"/>
    </test>
    
    <!--test with _include-->
    <test>
        <name value="Test scenario 1 - Retrieve Immunization resources including patient and performer"/>
        <description value="Query Immunization resource"/>
        <nts:include value="medmij/test.phr.search" scope="common" resource="Immunization" params="?_include=Immunization:patient&amp;_include=Immunization:performer"/>
        <nts:include value="canary-assert.response.successfulSearch" scope="common"/>
        <nts:include value="assert.response.numResources" scope="common" resource="Immunization" count="7"/>
        <nts:include value="assert.response.numResources" scope="common" resource="Patient" count="1"/>
        <nts:include value="assert.response.numResources" scope="common" resource="Organization" count="2"/> <!--deze count zou 1 moeten zijn-->
        
        <nts:include value="assert.numIdentifier" direction="response" resource="Immunization" count="7"/>
        <nts:include value="assert.numMedicationReference" direction="response" resource="Immunization" count="7"/>
    </test>
</TestScript>
