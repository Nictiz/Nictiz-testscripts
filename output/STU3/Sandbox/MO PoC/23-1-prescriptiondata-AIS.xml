<?xml version="1.0" encoding="UTF-8"?>
<TestScript xmlns="http://hl7.org/fhir" xmlns:nts="http://nictiz.nl/xsl/testscript">
   <id value="23-1-prescriptiondata-AIS"/>
   <url value="http://nictiz.nl/fhir/TestScript/AIS-send-MVE"/>
   <version value="r4-MP9.3.0.0-rc2"/>
   <name value="23.1_prescriptiondata_AIS"/>
   <title value="AIS prescription data"/>
   <status value="active"/>
   <publisher value="Nictiz"/>
   <contact>
      <name value="Nictiz"/>
      <telecom>
         <system value="email"/>
         <value value="kwalificatie@nictiz.nl"/>
         <use value="work"/>
      </telecom>
   </contact>
   <description value="Scenario 23.1: AIS sends MVE response based on received MA and follows with an prescription MA"/>
   <origin>
      <extension url="http://fhir.interoplab.eu/fhir/StructureDefinition/Interoplab-CL-ext-SUT">
         <valueBoolean value="false"/>
      </extension>
      <index value="1"/>
      <profile>
         <system value="http://terminology.hl7.org/CodeSystem/testscript-profile-origin-types"/>
         <code value="FHIR-Client"/>
      </profile>
   </origin>
   <origin>
      <extension url="http://fhir.interoplab.eu/fhir/StructureDefinition/Interoplab-CL-ext-SUT">
         <valueBoolean value="true"/>
      </extension>
      <index value="2"/>
      <profile>
         <system value="http://terminology.hl7.org/CodeSystem/testscript-profile-origin-types"/>
         <code value="FHIR-Client"/>
      </profile>
   </origin>
   <destination>
      <extension url="http://fhir.interoplab.eu/fhir/StructureDefinition/Interoplab-CL-ext-SUT">
         <valueBoolean value="true"/>
      </extension>
      <index value="1"/>
      <profile>
         <system value="http://terminology.hl7.org/CodeSystem/testscript-profile-destination-types"/>
         <code value="FHIR-Server"/>
      </profile>
   </destination>
   <destination>
      <extension url="http://fhir.interoplab.eu/fhir/StructureDefinition/Interoplab-CL-ext-SUT">
         <valueBoolean value="false"/>
      </extension>
      <index value="2"/>
      <profile>
         <system value="http://terminology.hl7.org/CodeSystem/testscript-profile-destination-types"/>
         <code value="FHIR-Server"/>
      </profile>
   </destination>
   <fixture id="initial-MA-fixture">
      <!-- Voor nu eoverdracht task tot ik een echte MA voorbeeld heb -->
      <autocreate value="false"/>
      <autodelete value="false"/>
      <resource>
         <reference value="../_reference/resources/resources-specific/eOverdracht-Task-eov-test-1_1-IN-PROGRESS2.xml"/>
      </resource>
   </fixture>
   <profile id="Bundle-profile"
            value="http://hl7.org/fhir/StructureDefinition/Bundle"/>
   <variable>
      <!-- Aanpassen naar juiste patient -->
      <name value="patient-token-id"/>
      <defaultValue value="Bearer 97294e63-092d-4554-a18a-9d60de7a726d"/>
      <description value="OAuth Token for current patient"/>
   </variable>
   <variable>
      <!--Change this to the actual MA ID, more info about variable see Interoplob IG-->
      <name value="MA-id"/>
      <defaultValue value="eOverdracht-Task-eov-${CD6}"/>
   </variable>
    <setup>
      <action>
         <operation>
            <type>
               <system value="http://hl7.org/fhir/restful-interaction"/>
               <code value="transaction"/>
            </type>
            <description value="To the AIS, a new MA is created."/>
            <destination value="1"/>
            <encodeRequestUrl value="true"/>
            <origin value="1"/>
            <requestHeader>
               <field value="Authorization"/>
               <value value="${patient-token-id}"/>
            </requestHeader>
            <responseId value="receive-MA-response"/>
            <sourceId value="initial-MA-fixture"/>
         </operation>
      </action>
      <action>
         <assert>
            <description value="Confirm that the operation was successful"/>
            <operator value="in"/>
            <responseCode value="200,201"/>
            <stopTestOnFail value="true"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </setup>
   <test>
      <name value="Serve MVE"/>
      <description value="The AIS sends the MVE response based on the created MA."/>
      <action>
         <operation>
            <type>
               <system value="http://hl7.org/fhir/restful-interaction"/>
               <code value="transaction"/> 
            </type>
            <description value="Test AIS to serve MVE."/>
            <destination value="2"/>
            <encodeRequestUrl value="true"/>
            <origin value="2"/>
            <requestHeader>
               <field value="Authorization"/>
               <value value="${patient-token-id}"/>
            </requestHeader>
            <responseId value="MVE-response"/>
         </operation>
      </action>
      <action>
         <assert>
            <description value="Confirm that the operation was successful"/>
            <operator value="in"/>
            <responseCode value="200,201"/>
            <stopTestOnFail value="true"/>
            <warningOnly value="false"/>
         </assert>
      </action>
      <!--Other assertions are added here-->
   </test>
   <test>
      <name value="Serve Prescription MA"/>
      <description value="The AIS sends a prescription MA after the MVE is processed."/>
      <action>
         <operation>
            <type>
               <system value="http://hl7.org/fhir/restful-interaction"/>
               <code value="transaction"/> 
            </type>
            <description value="Test AIS to serve prescription MA."/>
            <destination value="1"/>
            <encodeRequestUrl value="true"/>
            <origin value="1"/>
            <requestHeader>
               <field value="Authorization"/>
               <value value="${patient-token-id}"/>
            </requestHeader>
            <requestId value="prescription-MA-request"/>
            <responseId value="prescription-MA-response"/>
            <sourceId value="initial-MA-fixture"/>
         </operation>
      </action>
      <action>
         <assert>
            <description value="Confirm that the operation was successful"/>
            <operator value="in"/>
            <responseCode value="200,201"/>
            <stopTestOnFail value="true"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
</TestScript>
