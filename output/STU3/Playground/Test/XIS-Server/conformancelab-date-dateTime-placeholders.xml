
<TestScript xmlns="http://hl7.org/fhir">
   <id value="conformancelab-date-dateTime-placeholders"/>
   <meta>
      <profile value="http://fhir.interoplab.eu/fhir/StructureDefinition/Interoplab-CL-TestScript-core"/>
   </meta>
   <url value="http://fhir.interoplab.eu/fhir/TestScript/conformancelab-date-dateTime-placeholders"/>
   <version value="1.0.0"/>
   <name value="Conformancelab_date_dateTime_placeholders"/>
   <title value="Conformancelab date dateTime Placeholders"/>
   <status value="active"/>
   <publisher value="Interoplab"/>
   <contact>
      <name value="Interoplab"/>
      <telecom>
         <system value="email"/>
         <value value="support@interoplab.nl"/>
         <use value="work"/>
      </telecom>
   </contact>
   <description value="Test asserts with expressions"/>
   <origin>
      <extension url="http://fhir.interoplab.eu/fhir/StructureDefinition/Interoplab-CL-ext-SUT">
         <valueBoolean value="false"/>
      </extension>
      <index value="1"/>
      <profile>
         <system value="http://terminology.hl7.org/CodeSystem/testscript-profile-origin-types"/>
         <code value="FHIR-Client"/>
      </profile>
   </origin>
   <destination>
      <extension url="http://fhir.interoplab.eu/fhir/StructureDefinition/Interoplab-CL-ext-SUT">
         <valueBoolean value="true"/>
      </extension>
      <index value="1"/>
      <profile>
         <system value="http://terminology.hl7.org/CodeSystem/testscript-profile-destination-types"/>
         <code value="FHIR-Server"/>
      </profile>
   </destination>
   <fixture id="Observation">
      <autocreate value="false"/>
      <autodelete value="false"/>
      <resource>
         <reference value="_reference/Observation-date-dateTime.xml"/>
      </resource>
   </fixture>
   <variable>
      <name value="observation-id"/>
      <defaultValue value="Observation-${RANDOM-6}"/>
   </variable>
   <variable>
      <name value="T"/>
      <defaultValue value="2026-01-15"/>
      <description value="Date that data and queries are expected to be relative to."/>
   </variable>
   <variable>
      <name value="T2"/>
      <defaultValue value="2026-01-15T08:00:00"/>
      <description value="DateTime that data and queries are expected to be relative to."/>
   </variable>
   <variable>
      <name value="T3"/>
      <defaultValue value="2026-01-15T08:00:00+06:00"/>
      <description value="DateTime that data and queries are expected to be relative to."/>
   </variable>
   <setup>
      <action>
         <operation>
            <type>
               <system value="http://hl7.org/fhir/restful-interaction"/>
               <code value="update"/>
            </type>
            <resource value="Observation"/>
            <description value="Create example Observation"/>
            <accept value="xml"/>
            <contentType value="xml"/>
            <destination value="1"/>
            <encodeRequestUrl value="true"/>
            <params value="/${observation-id}"/>
            <sourceId value="Observation"/>
         </operation>
      </action>
      <action>
         <assert>
            <description value="Confirm that the operation was successful"/>
            <operator value="in"/>
            <responseCode value="200,201"/>
            <stopTestOnFail value="true"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </setup>
   <test id="dateTime">
      <name value="date-dateTime"/>
      <description value="Test various variants of the DATE and DATETIME placeholder functions"/>
      <action>
         <operation>
            <type>
               <system value="http://hl7.org/fhir/restful-interaction"/>
               <code value="read"/>
            </type>
            <resource value="Observation"/>
            <description value="Read Observation resource."/>
            <destination value="1"/>
            <encodeRequestUrl value="true"/>
            <origin value="1"/>
            <params value="${observation-id}"/>
         </operation>
      </action>
      <action>
         <assert>
            <description value="Confirm that the operation was successful"/>
            <operator value="in"/>
            <responseCode value="200,201"/>
            <stopTestOnFail value="true"/>
            <warningOnly value="false"/>
         </assert>
      </action>
   </test>
   <teardown>
      <action>
         <operation>
            <type>
               <system value="http://hl7.org/fhir/restful-interaction"/>
               <code value="delete"/>
            </type>
            <resource value="Observation"/>
            <description value="Delete example Observation"/>
            <destination value="1"/>
            <encodeRequestUrl value="true"/>
            <params value="/${observation-id}"/>
         </operation>
      </action>
   </teardown>
</TestScript>
